      "settings": {
        "custom_liquid": "{% assign product = all_products['custom-order'] %}\n{% if product == nil %}\n  <p style=\"color:red;\">⚠️ ERROR: Product handle 'custom-order' not found.</p>\n{% endif %}\n\n<style>\n/* ========================================================= */\n/* ANIMATIONS */\n/* ========================================================= */\n\n.upload-note {\n  font-size: 11px !important;\n  color: #9b9b9b !important;\n  opacity: 0.75 !important;\n  margin-top: 6px;\n  text-align: center;\n}\n\n\n/* Homepage “Add to Cart” pulse */\n.byo-instruction-highlight {\n  animation: byoInstructionPulse 1s ease-out 1;\n  color: #7CFF8A !important;\n}\n@keyframes byoInstructionPulse {\n  0% { opacity: 0.5; transform: scale(0.96); text-shadow:0 0 0 rgba(124,255,138,0.4); }\n  50% { opacity: 1; transform: scale(1.03); text-shadow:0 0 6px rgba(124,255,138,0.6); }\n  100% { opacity: 1; transform: scale(1); text-shadow:0 0 0 rgba(124,255,138,0); }\n}\n\n/* Step 3 Done button pulse */\n.byo-done-pulse {\n  animation: byoPulse 0.9s ease-out 1;\n  box-shadow: 0 0 0 rgba(124,255,138,0.3);\n}\n@keyframes byoPulse {\n  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(124,255,138,0.4); }\n  50% { transform: scale(1.04); box-shadow: 0 0 10px 5px rgba(124,255,138,0.4); }\n  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(124,255,138,0); }\n}\n\n/* Hide upload icon */\n.upload-icon-wrapper.hidden { display:none !important; }\n\n/* ========================================================= */\n/* UPLOAD SECTION */\n/* ========================================================= */\n.upload-section { text-align:center; }\n.upload-label {\n  font-size:12px; color:#ededed; letter-spacing:.09em; text-transform:uppercase;\n  margin-bottom:8px; display:block;\n}\n.upload-box {\n  border:1px dashed #444; border-radius:12px; padding:20px;\n  cursor:pointer; position:relative; transition:.25s ease;\n}\n.upload-box:hover { background:#1d1d1d; }\n.upload-box input {\n  position:absolute; inset:0; opacity:0; cursor:pointer;\n}\n.upload-icon-wrapper { display:flex; flex-direction:column; align-items:center; }\n.upload-icon { width:36px; opacity:.7; margin-bottom:6px; }\n.upload-main-text { font-size:12px; color:#dcdcdc; opacity:.9; }\n\n.upload-success { display:none; margin-top:8px; display:flex; flex-direction:column; align-items:center; }\n.checkmark { width:40px; stroke:#7CFF8A; stroke-width:3; }\n.checkmark-circle { stroke-dasharray:166; stroke-dashoffset:166; animation:circleAnim .6s forwards; }\n.checkmark-check { stroke-dasharray:48; stroke-dashoffset:48; animation:checkAnim .35s .25s forwards; }\n@keyframes circleAnim{ to{ stroke-dashoffset:0; } }\n@keyframes checkAnim{ to{ stroke-dashoffset:0; } }\n\n.upload-status-text { color:#7CFF8A; font-size:11px; margin-top:4px; }\n\n.upload-preview-list {\n  margin-top:12px; display:flex; gap:8px; flex-wrap:wrap; justify-content:center;\n}\n.upload-thumb {\n  width:55px; height:55px; border-radius:8px; object-fit:cover; border:1px solid #333;\n}\n\n.clear-upload-btn {\n  margin-top:10px; background:#2a2a2a; color:#fff;\n  padding:8px 14px; border-radius:8px; border:1px solid #444;\n  font-size:11px; text-transform:uppercase; letter-spacing:.07em;\n}\n.clear-upload-btn:hover { background:#383838; }\n\n/* ========================================================= */\n/* MAIN CARD */\n/* ========================================================= */\n.byo-wrap {\n  background:#151515; padding:18px 16px 20px; border-radius:16px; color:#fff;\n}\n.byo-header-line { display:flex; justify-content:space-between; align-items:center; }\n.byo-title { font-size:16px; font-weight:600; text-transform:uppercase; letter-spacing:.08em; }\n.byo-tagline { font-size:11px; opacity:.7; text-transform:uppercase; letter-spacing:.14em; }\n.byo-price { font-size:14px; }\n\n.byo-actions { display:flex; gap:10px; margin-top:12px; }\n.byo-btn, .byo-add-btn {\n  flex:1; padding:10px 14px; border:none; border-radius:999px;\n  text-transform:uppercase; font-size:13px; letter-spacing:.08em; cursor:pointer;\n}\n.byo-btn { background:#f5f5f5; color:#111; }\n.byo-btn::before { content:\"+\"; margin-right:6px; }\n.byo-add-btn { background:#000; color:#fff; }\n\n.byo-small-row {\n  display:flex; justify-content:space-between; font-size:11px;\n  margin-top:4px; opacity:.8;\n}\n\n.byo-upload-preview{\n  display:none; align-items:center; gap:8px; margin-top:8px; font-size:11px;\n}\n.byo-upload-preview img {\n  width:40px; height:40px; border-radius:6px; object-fit:cover;\n}\n/* ========================================================= */\n/* MODAL */\n/* ========================================================= */\n.byo-modal {\n  position:fixed; inset:0; display:none; justify-content:center; align-items:flex-end;\n  background:rgba(0,0,0,.55); backdrop-filter:blur(8px); z-index:9999;\n}\n.byo-modal-inner {\n  background:#141414; width:100%; max-width:480px;\n  border-radius:18px 18px 0 0; padding:16px 16px 22px;\n}\n.byo-modal-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }\n.byo-modal-title { font-size:15px; letter-spacing:.12em; text-transform:uppercase; }\n.byo-close { background:none; border:none; font-size:20px; color:#fff; }\n\n/* steps */\n.byo-steps { display:flex; gap:10px; margin-bottom:10px; }\n.byo-step-pill {\n  flex:1; padding:6px 8px; text-align:center; border-radius:999px;\n  border:1px solid #333; opacity:.65; font-size:10px; text-transform:uppercase;\n}\n.byo-step-pill.active { border-color:#fff; opacity:1; }\n\n.byo-step-panel{ display:none; }\n.byo-step-panel.active{ display:block; }\n\n/* variants */\n.byo-variant-row {\n  display:flex; overflow-x:auto; gap:8px; scrollbar-width:none;\n  padding:4px 2px 8px; -webkit-overflow-scrolling:touch;\n}\n.byo-variant-row::-webkit-scrollbar{ display:none; }\n.byo-variant-btn {\n  padding:8px 10px; border-radius:999px; border:1px solid #444;\n  white-space:nowrap; background:#202020; font-size:11px; color:#f5f5f5;\n}\n.byo-variant-btn.active { background:#2b2b2b; border-color:#fff; }\n\n/* Step 3 thumbnails */\n.byo-summary-thumbs {\n  margin-top:6px; display:flex; gap:6px; flex-wrap:wrap;\n}\n.byo-summary-thumbs img {\n  width:32px; height:32px; border-radius:6px; border:1px solid #333; object-fit:cover;\n}\n\n/* notes */\n.byo-notes { margin-top:12px; }\n.byo-notes-label { font-size:11px; opacity:.8; margin-bottom:4px; text-transform:uppercase; }\n.byo-notes-textarea {\n  width:100%; min-height:70px; background:#151515; color:#fff;\n  border-radius:10px; border:1px solid #333; padding:8px; font-size:12px;\n  resize:vertical;\n}\n\n/* modal nav */\n.byo-modal-nav { display:flex; gap:10px; margin-top:14px; }\n.byo-nav-btn {\n  flex:1; padding:8px 12px; border-radius:999px; border:1px solid #333;\n  background:#1d1d1d; text-transform:uppercase; color:#fff; font-size:11px;\n}\n.byo-nav-btn.primary { background:#f5f5f5; color:#111; }\n\n</style>\n\n<!-- ========================================================= -->\n<!-- MAIN CARD -->\n<!-- ========================================================= -->\n<div class=\"byo-wrap\">\n  <div class=\"byo-header-line\">\n    <div>\n      <h2 class=\"byo-title\">{{ product.title }}</h2>\n      <div class=\"byo-tagline\">Build your own smoking setup</div>\n    </div>\n    <div class=\"byo-price\" id=\"byoPrice\">{{ product.price | money | strip_html }}</div>\n  </div>\n\n  <div class=\"byo-actions\">\n    <button type=\"button\" class=\"byo-btn\" id=\"byoOpen\">Customize</button>\n    <button type=\"submit\" form=\"byoForm\" class=\"byo-add-btn\" name=\"add\">Add to cart</button>\n  </div>\n\n  <div class=\"byo-small-row\">\n    <span id=\"byoChosenText\">Option: not selected</span>\n    <span id=\"byoInstruction\">Step 1: Tap “Customize”</span>\n  </div>\n\n  <!-- homepage preview -->\n  <div class=\"byo-upload-preview\" id=\"byoPreviewWrap\">\n    <img id=\"byoPreviewImg\">\n    <span id=\"byoPreviewCount\"></span>\n  </div>\n\n<form method=\"post\"\n      action=\"/cart/add\"\n      id=\"byoForm\"\n      class=\"product-form\"\n      data-add-to-cart-form\n      data-product-id=\"{{ product.id }}\"\n      data-product-handle=\"{{ product.handle }}\">\n\n    <input type=\"hidden\" id=\"byoVariantInput\" name=\"id\">\n    <input type=\"hidden\" name=\"quantity\" value=\"1\">\n\n    <input type=\"hidden\" id=\"byoComboNote\" name=\"properties[Combo suggestion]\">\n    <input type=\"hidden\" id=\"byoNotes\" name=\"properties[Image placement notes]\">\n</form></div>\n\n<!-- ========================================================= -->\n<!-- MODAL -->\n<!-- ========================================================= -->\n<div class=\"byo-modal\" id=\"byoModal\">\n  <div class=\"byo-modal-inner\">\n\n    <div class=\"byo-modal-top\">\n      <div class=\"byo-modal-title\">Build your kit</div>\n      <button class=\"byo-close\" id=\"byoClose\">&times;</button>\n    </div>\n\n    <div class=\"byo-steps\">\n      <div class=\"byo-step-pill active\" data-step=\"1\">1. Choose combo</div>\n      <div class=\"byo-step-pill\" data-step=\"2\">2. Upload art</div>\n      <div class=\"byo-step-pill\" data-step=\"3\">3. Review</div>\n    </div>\n\n    <!-- STEP 1 -->\n    <div class=\"byo-step-panel byo-step-1 active\">\n      <p style=\"font-size:12px;opacity:.8;margin-bottom:6px;\">Pick the combo you want to build:</p>\n      <div class=\"byo-variant-row\">\n        {% for variant in product.variants %}\n          <button type=\"button\"\n            class=\"byo-variant-btn\"\n            data-id=\"{{ variant.id }}\"\n            data-title=\"{{ variant.title | escape }}\"\n            data-price=\"{{ variant.price | money | strip_html }}\">\n            {{ variant.title }}\n          </button>\n        {% endfor %}\n      </div>\n\n      <div class=\"byo-recs\" style=\"font-size:11px;opacity:.8;margin-top:6px;\">\n        <strong>Popular:</strong> Grinder + Jar • Full Grinder Set (Grinder + Jar + Tray) • Full Box Set (Stashbox + Jar + Grinder + Lighter)\n      </div>\n    </div>\n\n    <!-- STEP 2 -->\n    <div class=\"byo-step-panel byo-step-2\">\n      <div class=\"upload-section\">\n\n        <label class=\"upload-label\">Upload your artwork</label>\n\n        <div class=\"upload-box\">\n          <input type=\"file\" id=\"byoUploadInput\" accept=\"image/*\" multiple>\n\n          <div class=\"upload-icon-wrapper\">\n            <svg class=\"upload-icon\" viewBox=\"0 0 24 24\"><path fill=\"#aaa\" d=\"M...\"/></svg>\n            <span class=\"upload-main-text\">Tap to upload</span>\n          </div>\n\n          <div class=\"upload-success\" id=\"byoUploadSuccess\">\n            <svg class=\"checkmark\" viewBox=\"0 0 52 52\">\n              <circle class=\"checkmark-circle\" cx=\"26\" cy=\"26\" r=\"25\" fill=\"none\"/>\n              <path class=\"checkmark-check\" fill=\"none\" d=\"M14 27l7 7 17-17\"/>\n            </svg>\n            <span class=\"upload-status-text\">Uploaded</span>\n          </div>\n        </div>\n\n        <div class=\"upload-preview-list\" id=\"byoPreviewList\"></div>\n        <button class=\"clear-upload-btn\" id=\"clearUploadsBtn\" style=\"display:none;\">Clear uploads</button>\n\n        <p class=\"upload-note\">You can upload multiple images. Or click next and tell us your theme — anime, games, pop culture, anything.</p>\n\n      </div>\n    </div>\n\n    <!-- STEP 3 -->\n    <div class=\"byo-step-panel byo-step-3\">\n      <div class=\"byo-summary\">\n        <div><strong>Selected combo:</strong> <span id=\"byoSummaryVariant\">None</span></div>\n        <div><strong>Price:</strong> <span id=\"byoSummaryPrice\">{{ product.price | money | strip_html }}</span></div>\n\n        <div id=\"byoSummaryImage\" style=\"margin-top:6px;display:none;\">\n          <strong>\n            Custom images: <span id=\"byoSummaryCountText\"></span>\n          </strong>\n          <div class=\"byo-summary-thumbs\" id=\"byoSummaryThumbs\"></div>\n        </div>\n      </div>\n\n      <div class=\"byo-notes\">\n        <div class=\"byo-notes-label\">Tell us which image goes on which item</div>\n<textarea id=\"byoNotesInput\" class=\"byo-notes-textarea\" placeholder=\"Example: Image 1 → Grinder, Image 2 → Jar, Image 3 → Tray, Image 4 → Lighter.\"></textarea>\n      </div>\n    </div>\n\n    <div class=\"byo-modal-nav\">\n      <button type=\"button\" class=\"byo-nav-btn\" id=\"byoBack\">Back</button>\n      <button type=\"button\" class=\"byo-nav-btn primary\" id=\"byoNext\">Next</button>\n    </div>\n\n  </div>\n</div>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n\n  /* ELEMENTS */\n  const modal = document.getElementById(\"byoModal\");\n  const openBtn = document.getElementById(\"byoOpen\");\n  const closeBtn = document.getElementById(\"byoClose\");\n  const nextBtn = document.getElementById(\"byoNext\");\n  const backBtn = document.getElementById(\"byoBack\");\n\n  const stepPills = document.querySelectorAll(\".byo-step-pill\");\n  const stepPanels = document.querySelectorAll(\".byo-step-panel\");\n\n  const variantButtons = document.querySelectorAll(\".byo-variant-btn\");\n  const variantInput = document.getElementById(\"byoVariantInput\");\n\n  const chosenText = document.getElementById(\"byoChosenText\");\n  const priceDisplay = document.getElementById(\"byoPrice\");\n  const summaryVariant = document.getElementById(\"byoSummaryVariant\");\n  const summaryPrice = document.getElementById(\"byoSummaryPrice\");\n  /* Upload elements */\n  const input = document.getElementById(\"byoUploadInput\");\n  const success = document.getElementById(\"byoUploadSuccess\");\n  const previewList = document.getElementById(\"byoPreviewList\");\n  const clearBtn = document.getElementById(\"clearUploadsBtn\");\n\n  const summaryImage = document.getElementById(\"byoSummaryImage\");\n  const summaryCountText = document.getElementById(\"byoSummaryCountText\");\n  const summaryThumbs = document.getElementById(\"byoSummaryThumbs\");\n\n  const homepagePreview = document.getElementById(\"byoPreviewWrap\");\n  const homepagePreviewImg = document.getElementById(\"byoPreviewImg\");\n  const homepagePreviewCount = document.getElementById(\"byoPreviewCount\");\n\n  const instructionText = document.getElementById(\"byoInstruction\");\n\n  const notesInput = document.getElementById(\"byoNotesInput\");\n  const notesHidden = document.getElementById(\"byoNotes\");\n\n  const form = document.getElementById(\"byoForm\");\n\n  let currentStep = 1;\n\n  /* ========================================================= */\n  /* STEP SYSTEM */\n  /* ========================================================= */\n  function setStep(step) {\n    currentStep = step;\n\n    stepPills.forEach(p =>\n      p.classList.toggle(\"active\", Number(p.dataset.step) === step)\n    );\n\n    stepPanels.forEach((panel, idx) =>\n      panel.classList.toggle(\"active\", idx === step - 1)\n    );\n\n    nextBtn.textContent = (step === 3) ? \"Done\" : \"Next\";\n\n    if (step === 2) {\n      if (success) success.style.display = \"none\";\n\n      const iconWrapper = document.querySelector(\".upload-icon-wrapper\");\n      if (iconWrapper) iconWrapper.classList.remove(\"hidden\");\n\n      if (!input.files.length) {\n        previewList.innerHTML = \"\";\n        clearBtn.style.display = \"none\";\n      }\n    }\n\n    if (step === 3) {\n      nextBtn.classList.add(\"byo-done-pulse\");\n      setTimeout(() => nextBtn.classList.remove(\"byo-done-pulse\"), 900);\n    }\n  }\n\n  /* OPEN / CLOSE MODAL */\n  openBtn.addEventListener(\"click\", () => {\n    modal.style.display = \"flex\";\n    setStep(1);\n  });\n\n  closeBtn.addEventListener(\"click\", () => {\n    modal.style.display = \"none\";\n  });\n\n  modal.addEventListener(\"click\", e => {\n    if (e.target === modal) modal.style.display = \"none\";\n  });\n\n  /* NEXT BUTTON */\n  nextBtn.addEventListener(\"click\", () => {\n    if (currentStep === 1 && !variantInput.value) {\n      alert(\"Choose a combo first.\");\n      return;\n    }\n\n    if (currentStep < 3) {\n      setStep(currentStep + 1);\n      return;\n    }\n\n    modal.style.display = \"none\";\n\n    if (notesHidden && notesInput) {\n      notesHidden.value = notesInput.value.trim();\n    }\n\n    const uploadedImgsCount = document.querySelectorAll(\"input[name^='properties[Uploaded Image']\").length;\n\n    if (instructionText) {\n      instructionText.textContent =\n        uploadedImgsCount > 0\n          ? \"You're all set — Add to Cart!\"\n          : \"Customize complete — Add to Cart\";\n\n      instructionText.classList.add(\"byo-instruction-highlight\");\n      setTimeout(() => {\n        instructionText.classList.remove(\"byo-instruction-highlight\");\n      }, 1000);\n    }\n  });\n\n  /* BACK BUTTON */\n  backBtn.addEventListener(\"click\", () => {\n    if (currentStep > 1) {\n      setStep(currentStep - 1);\n    } else {\n      modal.style.display = \"none\";\n    }\n  });\n\n  /* ========================================================= */\n  /* VARIANT SELECTION */\n  /* ========================================================= */\n  variantButtons.forEach(btn => {\n    btn.addEventListener(\"click\", () => {\n      variantButtons.forEach(b => b.classList.remove(\"active\"));\n      btn.classList.add(\"active\");\n\n      const id = btn.dataset.id;\n      const title = btn.dataset.title;\n      const price = btn.dataset.price;\n\n      variantInput.value = id;\n      chosenText.textContent = \"Option: \" + title;\n      priceDisplay.textContent = price;\n      summaryPrice.textContent = price;\n      summaryVariant.textContent = title;\n    });\n  });\n\n  /* ========================================================= */\n  /* IMAGE UPLOAD HANDLING */\n  /* ========================================================= */\n  input.addEventListener(\"change\", () => {\n    const files = Array.from(input.files);\n\n    previewList.innerHTML = \"\";\n    summaryThumbs.innerHTML = \"\";\n\n    const iconWrapper = document.querySelector(\".upload-icon-wrapper\");\n    if (iconWrapper) iconWrapper.classList.add(\"hidden\");\n\n    success.style.display = \"flex\";\n    clearBtn.style.display = \"block\";\n\n    [...form.querySelectorAll(\"input[name^='properties[Uploaded Image']\")].forEach(el => el.remove());\n\n    if (files.length === 0) {\n      summaryImage.style.display = \"none\";\n      homepagePreview.style.display = \"none\";\n      return;\n    }\n\n    files.forEach((file, index) => {\n      const reader = new FileReader();\n\n      reader.onload = e => {\n        const base64 = e.target.result;\n\n        const img = document.createElement(\"img\");\n        img.src = base64;\n        img.classList.add(\"upload-thumb\");\n        previewList.appendChild(img);\n\n        if (index === 0) {\n          homepagePreviewImg.src = base64;\n          homepagePreview.style.display = \"flex\";\n        }\n\n        const tiny = document.createElement(\"img\");\n        tiny.src = base64;\n        summaryThumbs.appendChild(tiny);\n\n        const hidden = document.createElement(\"input\");\n        hidden.type = \"hidden\";\n        hidden.name = `properties[Uploaded Image ${index + 1}]`;\n        hidden.value = base64;\n        form.appendChild(hidden);\n      };\n\n      reader.readAsDataURL(file);\n    });\n\n    homepagePreviewCount.textContent =\n      files.length === 1 ? \"1 image added\" : `${files.length} images added`;\n\n    summaryCountText.textContent =\n      files.length === 1 ? \"1 image attached\" : `${files.length} images attached`;\n\n    summaryImage.style.display = \"block\";\n  });\n\n  /* CLEAR UPLOADS */\n  clearBtn.addEventListener(\"click\", () => {\n    const iconWrapper = document.querySelector(\".upload-icon-wrapper\");\n    if (iconWrapper) iconWrapper.classList.remove(\"hidden\");\n\n    previewList.innerHTML = \"\";\n    summaryThumbs.innerHTML = \"\";\n\n    homepagePreviewImg.src = \"\";\n    homepagePreviewCount.textContent = \"\";\n    homepagePreview.style.display = \"none\";\n\n    summaryImage.style.display = \"none\";\n    summaryCountText.textContent = \"\";\n\n    success.style.display = \"none\";\n    clearBtn.style.display = \"none\";\n    input.value = \"\";\n\n    [...form.querySelectorAll(\"input[name^='properties[Uploaded Image']\")].forEach(el => el.remove());\n  });\n\n  /* ========================================================= */\n  /* NEW AJAX ADD-TO-CART — FINAL FIX */\n  /* ========================================================= */\n  document.querySelector('.byo-add-btn').addEventListener('click', function(e) {\n    e.preventDefault();\n  \n    const variantId = document.getElementById('byoVariantInput').value;\n  \n    if (!variantId) {\n      alert('Please complete customization first');\n      return;\n    }\n  \n    let formData = {\n      id: variantId,\n      quantity: 1,\n      properties: {}\n    };\n  \n    const comboNote = document.getElementById('byoComboNote').value;\n    if (comboNote) {\n      formData.properties['Combo suggestion'] = comboNote;\n    }\n  \n    const notes = document.getElementById('byoNotes').value;\n    if (notes) {\n      formData.properties['Image placement notes'] = notes;\n    }\n  \n    const imageInputs = document.querySelectorAll('input[name^=\"properties[Uploaded Image\"]');\n    imageInputs.forEach(input => {\n      const match = input.name.match(/properties\\[(.+)\\]/);\n      if (match) {\n        formData.properties[match[1]] = input.value;\n      }\n    });\n  \n    console.log('Sending to cart:', formData);\n  \n    fetch('/cart/add.js', {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n      },\n      body: JSON.stringify(formData)\n    })\n    .then(response => response.json())\n    .then(data => {\n      console.log('Success:', data);\n      window.location.href = '/cart';\n    })\n    .catch((error) => {\n      console.error('Error:', error);\n      alert('Error adding to cart. Check console for details.');\n    });\n  });\n\n});\n</script>",
