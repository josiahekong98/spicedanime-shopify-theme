{%- liquid
  assign product_id = product_id | default: product.id
  assign product_recommendations_icon = icon | default: 'theme-package'
  assign product_recommendations_title = title | default: settings.cart_upsell_title | default: ''
  assign product_recommendations_limit = limit | default: 8
  assign product_recommendations_request_limit = product_recommendations_limit
  assign product_recommendations_mode = presentation_mode | default: 'complete-set'
  assign product_recommendations_standard_title = standard_title | default: 'You May Also Like'
  assign product_recommendations_is_complete_set = false
  if product_recommendations_mode == 'complete-set'
    assign product_recommendations_is_complete_set = true
  endif
  if area == 'cart-drawer'
    assign product_recommendations_limit = 3
    assign product_recommendations_request_limit = 10
  endif
-%}

{{- 'component-product-recommendations.css' | asset_url | stylesheet_tag -}}
{%- unless area == 'cart-drawer' -%}
  <script src="{{ 'product-recommendations.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<product-recommendations
  class="product-recommendations hidden {{ class }}{% if area == 'cart-drawer' %} sa-cart-upsell--{{ product_recommendations_mode }}{% endif %} color-{{ settings.color_scheme_for_upsell }}"
  data-url="{{- routes.product_recommendations_url -}}?section_id={{- section.id -}}&product_id={{- product_id -}}&limit={{- product_recommendations_request_limit -}}&intent=complementary"
  data-recommendation-area="{{- area -}}"
  {% if area == 'cart-drawer' %}
    data-sa-cart-mode="{{ product_recommendations_mode }}"
    data-sa-cart-recommendation-source="complementary"
    {% if product_recommendations_is_complete_set %}data-sa-cart-complete-set{% endif %}
  {% endif %}
>
  {%- if area == 'cart-drawer' and product_recommendations_is_complete_set -%}
    {%- render 'sa-cart-complete-set',
      source: 'complementary',
      title: product_recommendations_title,
      supporting_message: supporting_message
    -%}
  {%- elsif area == 'cart-drawer' and product_recommendations_standard_title != blank -%}
    <h5 class="product-recommendations__title">{{- product_recommendations_standard_title | escape -}}</h5>
  {%- elsif product_recommendations_title != blank -%}
    <h5 class="product-recommendations__title{% if template.name == 'cart' %} heading-static{% endif %}">
      {%- if icon -%}
        {% render 'icon', icon_name: product_recommendations_icon %}
      {%- endif -%}
      {{- product_recommendations_title | escape -}}
    </h5>
  {%- endif -%}

  <div class="swiper product-recommendations__body">
    <div class="product-recommendations__items swiper-wrapper" data-recommendations>
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- if area == 'cart-drawer' -%}
          {%- liquid
            assign cart_product_tokens = '|'
            assign seen_product_tokens = '|'
            assign rendered_recommendations = 0
            for line_item in cart.items
              assign cart_product_tokens = cart_product_tokens | append: line_item.product.id | append: '|'
            endfor
          -%}
          {%- for recommendation in recommendations.products -%}
            {%- liquid
              assign recommendation_token = recommendation.id | prepend: '|' | append: '|'
              assign recommendation_is_eligible = true
              if recommendation.available == false or recommendation.id == product_id
                assign recommendation_is_eligible = false
              elsif cart_product_tokens contains recommendation_token or seen_product_tokens contains recommendation_token
                assign recommendation_is_eligible = false
              endif
            -%}
            {%- if recommendation_is_eligible and rendered_recommendations < product_recommendations_limit -%}
              {%- liquid
                assign seen_product_tokens = seen_product_tokens | append: recommendation.id | append: '|'
                assign rendered_recommendations = rendered_recommendations | plus: 1
              -%}
              {%- render 'sa-cart-transfer-card', product: recommendation, selectable: product_recommendations_is_complete_set, source: 'complementary' -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for recommendation in recommendations.products limit: product_recommendations_limit -%}
            <a href="{{- recommendation.url -}}" class="product-recommendations__item swiper-slide">
              {%- if recommendation.featured_image -%}
                <div class="media product-recommendations__item-media">
                  {%- render 'image', image: recommendation.featured_image, alt: recommendation.featured_image.alt | escape -%}
                </div>
              {%- endif -%}

              <div class="product-recommendations__item-details">
                <div>
                  <h6 class="product-recommendations__item-title">
                    {{- recommendation.title | escape -}}
                  </h6>

                  <p class="product-recommendations__item-price">
                    {%- if recommendation.compare_at_price_min > recommendation.price_min -%}
                      <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
                      <del>{{- recommendation.compare_at_price_min | money -}}</del>
                      <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
                      <ins>{{- recommendation.price_min | money -}}</ins>
                    {%- else -%}
                      <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
                      {{- recommendation.price_min | money -}}
                    {%- endif -%}
                  </p>
                </div>

                {%- if settings.product_card_enable_quick_add_to_cart_button -%}
                  <button
                    type="button"
                    class="quick-cart-drawer__trigger quick-cart-drawer__trigger--recommendations button button--text"
                    aria-expanded="false"
                    onclick="preventDefault(event)"
                    aria-controls="quick-cart-drawer"
                    data-product-url="{{- recommendation.handle | prepend: '/products/'  -}}"
                  >
                    {{- 'cart.quick_add' | t -}}
                    <div class="quick-cart-drawer__trigger--loading">
                      {%- render 'loading-spinner' -%}
                    </div>
                  </button>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if area == 'cart-drawer' and product_recommendations_is_complete_set -%}
    <div data-sa-cart-complete-set-actions hidden>
      <button type="button" data-sa-cart-add-selected disabled>Add Selected Items</button>
    </div>
  {%- endif -%}
</product-recommendations>
