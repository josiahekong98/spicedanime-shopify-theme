{{- 'component-card-product.css' | asset_url | stylesheet_tag -}}
{{- 'sa-lifestyle-archive.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign main_path_count = 0
  assign vibe_path_count = 0
-%}

{%- capture main_path_cards -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'lifestyle_path' -%}
      {%- liquid
        assign path_page = block.settings.page
        assign path_collection = block.settings.collection
        assign path_products = block.settings.products
        if path_products == blank and path_collection != blank
          assign path_products = path_collection.products
        endif

        assign path_url = blank
        if path_page != blank
          assign path_url = path_page.url
        elsif path_collection != blank
          assign path_url = path_collection.url
        endif

        assign path_has_purpose = false
        if path_url != blank or path_products != blank
          assign path_has_purpose = true
        endif
      -%}

      {%- if path_has_purpose -%}
        {%- liquid
          assign main_path_count = main_path_count | plus: 1
          assign path_title = block.settings.title | default: path_page.title | default: path_collection.title
          assign path_image = block.settings.image | default: path_collection.image
          assign available_path_products = path_products | where: 'available'
          assign path_fallback_product = available_path_products.first | default: path_products.first
          assign path_image = path_image | default: path_fallback_product.featured_image
        -%}
        {%- render 'sa-lifestyle-archive-card',
          title: path_title,
          url: path_url,
          image: path_image,
          description: block.settings.description,
          cta: block.settings.cta,
          accent: block.settings.accent,
          index: main_path_count,
          accessibility_label: block.settings.accessibility_label,
          shopify_attributes: block.shopify_attributes,
          products: path_products,
          variant: 'main'
        -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture vibe_path_cards -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'vibe_path' -%}
      {%- liquid
        assign vibe_page = block.settings.page
        assign vibe_collection = block.settings.collection
        assign vibe_products = block.settings.products
        if vibe_products == blank and vibe_collection != blank
          assign vibe_products = vibe_collection.products
        endif

        assign vibe_url = blank
        if vibe_page != blank
          assign vibe_url = vibe_page.url
        elsif vibe_collection != blank
          assign vibe_url = vibe_collection.url
        endif

        assign vibe_has_purpose = false
        if vibe_url != blank or vibe_products != blank
          assign vibe_has_purpose = true
        endif
      -%}

      {%- if vibe_has_purpose -%}
        {%- liquid
          assign vibe_path_count = vibe_path_count | plus: 1
          assign vibe_title = block.settings.title | default: vibe_page.title | default: vibe_collection.title
          assign vibe_image = block.settings.image | default: vibe_collection.image
          assign available_vibe_products = vibe_products | where: 'available'
          assign vibe_fallback_product = available_vibe_products.first | default: vibe_products.first
          assign vibe_image = vibe_image | default: vibe_fallback_product.featured_image
        -%}
        {%- render 'sa-lifestyle-archive-card',
          title: vibe_title,
          url: vibe_url,
          image: vibe_image,
          description: block.settings.description,
          cta: block.settings.cta,
          accent: block.settings.accent,
          index: vibe_path_count,
          accessibility_label: block.settings.accessibility_label,
          shopify_attributes: block.shopify_attributes,
          products: vibe_products,
          variant: 'vibe'
        -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- liquid
  assign curated_products = section.settings.curated_products
  if curated_products == blank and section.settings.curated_collection != blank
    assign curated_products = section.settings.curated_collection.products
  endif
  assign curated_limit = section.settings.curated_limit | default: 8
  assign curated_count = 0
-%}

{%- capture curated_product_cards -%}
  {%- for product in curated_products limit: curated_limit -%}
    {%- if product != blank -%}
      {%- assign curated_count = curated_count | plus: 1 -%}
      <div class="sa-lifestyle-archive__product" role="listitem">
        {%- render 'card-product',
          product_ref: product,
          section_id: section.id,
          block_index: forloop.index
        -%}
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

<section
  class="sa-lifestyle-archive"
  aria-labelledby="sa-lifestyle-archive-title-{{ section.id }}"
>
  <div class="sa-lifestyle-archive__inner">
    <header class="sa-lifestyle-archive__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="sa-lifestyle-archive__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="sa-lifestyle-archive__title" id="sa-lifestyle-archive-title-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h1>
      {%- if section.settings.intro != blank -%}
        <p class="sa-lifestyle-archive__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </header>

    {%- if main_path_count > 0 -%}
      <div class="sa-lifestyle-archive__main-grid" role="list">
        {{- main_path_cards -}}
      </div>
    {%- endif -%}

    {%- if vibe_path_count > 0 -%}
      <section class="sa-lifestyle-archive__section" aria-labelledby="sa-lifestyle-vibes-title-{{ section.id }}">
        <header class="sa-lifestyle-archive__section-header">
          {%- if section.settings.vibe_eyebrow != blank -%}
            <p class="sa-lifestyle-archive__section-label">{{ section.settings.vibe_eyebrow | escape }}</p>
          {%- endif -%}
          <h2 id="sa-lifestyle-vibes-title-{{ section.id }}">{{ section.settings.vibe_heading | escape }}</h2>
        </header>
        <div class="sa-lifestyle-archive__vibe-grid" role="list">
          {{- vibe_path_cards -}}
        </div>
      </section>
    {%- endif -%}

    {%- if curated_count > 0 -%}
      <section class="sa-lifestyle-archive__section" aria-labelledby="sa-lifestyle-curated-title-{{ section.id }}">
        <header class="sa-lifestyle-archive__section-header">
          {%- if section.settings.curated_eyebrow != blank -%}
            <p class="sa-lifestyle-archive__section-label">{{ section.settings.curated_eyebrow | escape }}</p>
          {%- endif -%}
          <h2 id="sa-lifestyle-curated-title-{{ section.id }}">{{ section.settings.curated_heading | escape }}</h2>
          {%- if section.settings.curated_intro != blank -%}
            <p>{{ section.settings.curated_intro | escape }}</p>
          {%- endif -%}
        </header>
        <div class="sa-lifestyle-archive__product-row" role="list" aria-label="{{ section.settings.curated_heading | escape }}">
          {{- curated_product_cards -}}
        </div>
      </section>
    {%- endif -%}

    {%- if main_path_count == 0 and vibe_path_count == 0 and curated_count == 0 and request.design_mode -%}
      <p class="sa-lifestyle-archive__empty" role="status">
        Select a page, collection, or real products to publish a Lifestyle Archive path.
      </p>
    {%- endif -%}
  </div>
</section>

