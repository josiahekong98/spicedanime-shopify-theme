{%- comment -%}
  Same-series fallback for cart drawer Complete This Transfer. It stays hidden
  unless the Shopify recommendation endpoint returns no complementary products.
{%- endcomment -%}

{%- liquid
  assign transfer_title = title | default: settings.cart_upsell_title | default: 'Complete This Transfer'
  assign transfer_limit = limit | default: 4
  assign transfer_class = class | default: ''
  assign merchant_products = merchant_products | default: blank
  assign transfer_mode = presentation_mode | default: 'complete-set'
  assign transfer_standard_title = standard_title | default: 'You May Also Like'
  assign transfer_is_complete_set = false
  if transfer_mode == 'complete-set'
    assign transfer_is_complete_set = true
  endif
  assign anchor_item = blank
  assign anchor_product = anchor_product | default: blank
  assign cart_product_tokens = '|'

  for line_item in cart.items
    assign cart_product_tokens = cart_product_tokens | append: line_item.product.id | append: '|'
    if anchor_product == blank and anchor_item == blank and line_item.final_line_price > 0 and line_item.product.available
      assign anchor_item = line_item
      assign anchor_product = line_item.product
    endif
  endfor

  assign anchor_series = ''
  assign anchor_series_key = ''
  assign transfer_collection = blank

  if anchor_product != blank
    assign anchor_series = anchor_product.metafields.custom.series.value | default: anchor_product.metafields.custom.series | strip
    assign anchor_series_key = anchor_series | handleize
  endif

  if anchor_series_key != blank
    assign series_collection_candidates = anchor_series_key | append: '|' | append: anchor_series_key | append: '-anime-accessories|' | append: anchor_series_key | append: '-accessories|' | append: anchor_series_key | append: '-collection|' | append: anchor_series_key | append: '-products|' | append: anchor_series_key | append: '-smoking-accessories' | split: '|'

    for candidate_handle in series_collection_candidates
      if transfer_collection == blank and collections[candidate_handle] != blank
        assign transfer_collection = collections[candidate_handle]
      endif
    endfor

    if transfer_collection == blank
      for product_collection in anchor_product.collections
        assign product_collection_handle = product_collection.handle | handleize
        assign product_collection_title = product_collection.title | handleize
        if product_collection_handle == anchor_series_key or product_collection_title == anchor_series_key or product_collection_handle contains anchor_series_key or anchor_series_key contains product_collection_handle or product_collection_title contains anchor_series_key or anchor_series_key contains product_collection_title
          assign transfer_collection = product_collection
          break
        endif
      endfor
    endif
  endif

  assign rendered_count = 0
  assign seen_products = '|'
  assign transfer_has_source = false
  if transfer_collection != blank or merchant_products != blank
    assign transfer_has_source = true
  endif
  unless transfer_is_complete_set
    if standard_lighter_collection != blank or standard_tapestry_collection != blank or standard_pillow_collection != blank or standard_wallet_collection != blank or standard_tote_collection != blank
      assign transfer_has_source = true
    endif
  endunless
-%}

{%- if transfer_has_source -%}
  <div
    class="product-recommendations hidden {{ transfer_class }} sa-cart-upsell--{{ transfer_mode }} color-{{ settings.color_scheme_for_upsell }}"
    data-sa-cart-series-transfer-fallback
    data-sa-cart-mode="{{ transfer_mode }}"
    data-sa-cart-recommendation-source="fallback"
    {% if transfer_is_complete_set %}data-sa-cart-complete-set{% endif %}
    hidden
  >
    {%- if transfer_is_complete_set -%}
      {%- render 'sa-cart-complete-set',
        source: 'fallback',
        title: transfer_title,
        supporting_message: supporting_message
      -%}
    {%- elsif transfer_standard_title != blank -%}
      <h5 class="product-recommendations__title">{{- transfer_standard_title | escape -}}</h5>
    {%- endif -%}

    <div class="swiper product-recommendations__body">
      <div class="product-recommendations__items swiper-wrapper" data-recommendations>
        {%- if transfer_is_complete_set -%}
          {%- if transfer_collection != blank -%}
            {%- for recommendation in transfer_collection.products limit: 48 -%}
              {%- liquid
                assign recommendation_token = recommendation.id | prepend: '|' | append: '|'
                assign recommendation_series = recommendation.metafields.custom.series.value | default: recommendation.metafields.custom.series | strip
                assign recommendation_series_key = recommendation_series | handleize
              -%}
              {%- unless cart_product_tokens contains recommendation_token -%}
                {%- unless seen_products contains recommendation_token -%}
                  {%- if rendered_count < transfer_limit and recommendation.available and recommendation.id != anchor_product.id and recommendation_series_key == anchor_series_key -%}
                    {%- liquid
                      assign rendered_count = rendered_count | plus: 1
                      assign seen_products = seen_products | append: recommendation.id | append: '|'
                    -%}
                    {%- render 'sa-cart-transfer-card', product: recommendation, selectable: transfer_is_complete_set, source: 'fallback' -%}
                  {%- endif -%}
                {%- endunless -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}

          {%- if merchant_products != blank and rendered_count == 0 -%}
            {%- for recommendation in merchant_products -%}
              {%- assign recommendation_token = recommendation.id | prepend: '|' | append: '|' -%}
              {%- unless cart_product_tokens contains recommendation_token -%}
                {%- unless seen_products contains recommendation_token -%}
                  {%- if rendered_count < transfer_limit and recommendation.available and recommendation.id != anchor_product.id -%}
                    {%- liquid
                      assign rendered_count = rendered_count | plus: 1
                      assign seen_products = seen_products | append: recommendation.id | append: '|'
                    -%}
                    {%- render 'sa-cart-transfer-card', product: recommendation, selectable: transfer_is_complete_set, source: 'fallback' -%}
                  {%- endif -%}
                {%- endunless -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          {%- render 'sa-cart-standard-recommendations',
            anchor_product: anchor_product,
            merchant_products: merchant_products,
            lighter_collection: standard_lighter_collection,
            tapestry_collection: standard_tapestry_collection,
            pillow_collection: standard_pillow_collection,
            wallet_collection: standard_wallet_collection,
            tote_collection: standard_tote_collection,
            limit: transfer_limit
          -%}
        {%- endif -%}
      </div>
    </div>

    {%- if transfer_is_complete_set -%}
      <div data-sa-cart-complete-set-actions hidden>
        <button type="button" data-sa-cart-add-selected disabled>Add Selected Items</button>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
