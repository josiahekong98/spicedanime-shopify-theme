{% liquid
  assign family_url = url | default: fallback_url
  assign request_href = request_url | default: '/pages/contact'
  assign family_available = available | default: false
  assign family_count = count | default: 0
  assign family_href = family_url
  if family_href contains '?'
    assign family_href = family_href | append: '&filter.p.m.custom.series=' | append: series_filter
  else
    assign family_href = family_href | append: '?filter.p.m.custom.series=' | append: series_filter
  endif
%}

{% capture family_card_content %}
  <span class="sa-series-family-card__media">
    {% if image != blank %}
      <img src="{{ image | image_url: width: 560 }}" alt="{{ title | escape }}">
    {% else %}
      <span class="sa-series-family-card__fallback">{% if family_available %}Explore{% else %}Custom Request{% endif %}</span>
    {% endif %}
  </span>
  <span class="sa-series-family-card__label">
    <span class="sa-series-family-card__title">{{ title | escape }}</span>
    <span class="sa-series-family-card__count">
      {% if family_available %}
        Explore
      {% else %}
        Make a Custom Request
      {% endif %}
    </span>
  </span>
{% endcapture %}

{% if family_available %}
  <a class="sa-series-family-card sa-card" href="{{ family_href }}" role="listitem" aria-label="Shop {{ title | escape }}">
    {{ family_card_content }}
  </a>
{% else %}
  <a class="sa-series-family-card sa-series-family-card--quiet sa-card" href="{{ request_href }}" role="listitem" aria-label="Make a custom {{ title | escape }} request">
    {{ family_card_content }}
  </a>
{% endif %}
