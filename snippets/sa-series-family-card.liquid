{% liquid
  assign family_url = url | default: fallback_url
  assign family_available = available | default: false
  assign family_count = count | default: 0
  assign family_href = family_url
  if family_href contains '?'
    assign family_href = family_href | append: '&filter.p.m.custom.series=' | append: series_filter
  else
    assign family_href = family_href | append: '?filter.p.m.custom.series=' | append: series_filter
  endif
%}

{% capture family_card_content %}
  <span class="sa-series-family-card__media">
    {% if image != blank %}
      <img src="{{ image | image_url: width: 560 }}" alt="{{ title | escape }}">
    {% else %}
      <span class="sa-series-family-card__fallback">{% if family_available %}Explore{% else %}Coming Soon{% endif %}</span>
    {% endif %}
  </span>
  <span class="sa-series-family-card__label">
    <span class="sa-series-family-card__title">{{ title | escape }}</span>
    <span class="sa-series-family-card__count">
      {% if family_count > 0 %}
        {{ family_count }} {% if family_count == 1 %}Design{% else %}Designs{% endif %}
      {% elsif family_available %}
        Explore
      {% else %}
        Coming Soon
      {% endif %}
    </span>
  </span>
{% endcapture %}

{% if family_available %}
  <a class="sa-series-family-card" href="{{ family_href }}" role="listitem" aria-label="Shop {{ title | escape }}">
    {{ family_card_content }}
  </a>
{% else %}
  <div class="sa-series-family-card sa-series-family-card--quiet" role="listitem" aria-disabled="true">
    {{ family_card_content }}
  </div>
{% endif %}
