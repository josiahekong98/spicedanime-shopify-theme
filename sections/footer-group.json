      "settings": {
        "custom_liquid": "<style>\n/* WRAPPER – full bleed, breaks out of Shopify container */\n.anime-slider-wrap {\n  background:#1F1F1F;\n  padding:12px 0 0;\n  margin:0;\n  width:100vw;\n  position:relative;\n  left:50%;\n  right:50%;\n  margin-left:-50vw;\n  margin-right:-50vw;\n}\n\n/* HEADING */\n.anime-slider-heading {\n  margin:-20px 0 12px;\n  position: relative;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  padding: 0 16px;\n}\n\n/* TITLE */\n.anime-slider-heading span {\n  font-weight:300;\n  letter-spacing:.18em;\n  font-size:16px;\n  text-transform:uppercase;\n  color:#ededed;\n  margin: 0 auto;\n}\n\n/* VIEW ALL BUTTON */\n.anime-view-all {\n  position: absolute;\n  right: 12px;\n  font-size:10px;\n  letter-spacing:.12em;\n  text-transform:uppercase;\n  color:#dcdcdc;\n  opacity:.65;\n  text-decoration:none;\n}\n\n.anime-view-all:hover {\n  opacity:1;\n}\n\n/* SLIDER – edge-to-edge */\n.anime-slider {\n  display:flex;\n  overflow-x:auto;\n  gap:12px;\n  padding:0 0 4px;\n  margin:0;\n  scroll-snap-type:x mandatory;\n  -webkit-overflow-scrolling:touch;\n}\n\n/* Hide scrollbar fully */\n.anime-slider::-webkit-scrollbar { display: none; }\n.anime-slider { scrollbar-width: none; -ms-overflow-style: none; }\n\n/* CARD – show ~2.3 items */\n.anime-collection-card {\n  flex:0 0 40%;\n  scroll-snap-align:start;\n  text-align:center;\n  text-decoration:none;\n}\n\n/* IMAGE */\n.anime-collection-card img {\n  width:100%;\n  height:auto;\n  display:block;\n  transition:transform .18s ease;\n}\n\n.anime-collection-card:hover img {\n  transform:scale(1.025);\n}\n\n/* TITLE UNDER IMAGE */\n.anime-collection-title {\n  font-size:10px;\n  font-weight:400;\n  text-transform:uppercase;\n  letter-spacing:.14em;\n  margin-top:4px;\n  line-height:1.2;\n  color:#ededed;\n  display:inline-block;\n  position:relative;\n  padding-bottom:1px;\n}\n\n/* UNDERLINE HOVER */\n.anime-collection-title::after {\n  content:\"\";\n  position:absolute;\n  bottom:-1px;\n  left:0;\n  width:100%;\n  height:1px;\n  background:#dcdcdc;\n  transform:scaleX(0);\n  transform-origin:left center;\n  transition:transform .18s ease;\n}\n\n.anime-collection-card:hover .anime-collection-title::after {\n  transform:scaleX(1);\n}\n</style>\n\n\n\n<div class=\"anime-slider-wrap\">\n\n  <div class=\"anime-slider-heading\">\n    <span>SHOP BY ANIME</span>\n    <a href=\"/pages/all-anime-collections\" class=\"anime-view-all\">View All</a>\n  </div>\n\n  <div class=\"anime-slider\">\n    {% for collection in collections %}\n      {% if collection.title contains \"(Series)\" %}\n        {% assign clean_title = collection.title | replace: \"(Series)\", \"\" | strip %}\n        <a href=\"{{ collection.url }}\" class=\"anime-collection-card\">\n          {% if collection.image %}\n            <img src=\"{{ collection.image | img_url: '540x540' }}\" alt=\"{{ clean_title }}\">\n          {% endif %}\n          <div class=\"anime-collection-title\">{{ clean_title }}</div>\n        </a>\n      {% endif %}\n    {% endfor %}\n  </div>\n\n</div>\n\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n  const slider = document.querySelector(\".anime-slider\");\n  if (!slider) return;\n\n  let isDown = false;\n  let startX = 0;\n  let scrollLeft = 0;\n\n  slider.addEventListener(\"mousedown\", e => {\n    isDown = true;\n    startX = e.pageX - slider.offsetLeft;\n    scrollLeft = slider.scrollLeft;\n  });\n\n  slider.addEventListener(\"mouseleave\", () => { isDown = false; });\n  slider.addEventListener(\"mouseup\", () => { isDown = false; });\n\n  slider.addEventListener(\"mousemove\", e => {\n    if (!isDown) return;\n    e.preventDefault();\n    const x = e.pageX - slider.offsetLeft;\n    slider.scrollLeft = scrollLeft - (x - startX) * 1.5;\n  });\n});\n</script>",
        "section_width": "max-w-page",
