{% liquid
  assign section_label = section.settings.label | default: 'SERIES ARCHIVE'
  assign section_heading = section.settings.heading | default: 'Shop Top Performing Series'
  assign section_intro = section.settings.intro | default: 'Start with the fandom, then discover the product families, matching sets, and archive finds inside each series.'
  assign visible_count = section.settings.visible_count | plus: 0
  assign mobile_layout = section.settings.mobile_layout | default: 'grid'
%}

{{- 'sa-series-archive-card.css' | asset_url | stylesheet_tag -}}

<section class="sa-section sa-section--archive-black sa-top-series sa-top-series--mobile-{{ mobile_layout }}" aria-labelledby="sa-top-series-title-{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} .sa-top-series {
      padding-block: clamp(24px, 4vw, 40px);
    }

    #shopify-section-{{ section.id }} .sa-top-series__header {
      display: grid;
      gap: var(--sa-space-2);
      margin-block-end: 14px;
    }

    #shopify-section-{{ section.id }} .sa-top-series__header-row {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: var(--sa-space-5);
    }

    #shopify-section-{{ section.id }} .sa-top-series__heading-group {
      display: grid;
      gap: var(--sa-space-2);
      max-width: 780px;
    }

    #shopify-section-{{ section.id }} .sa-top-series__heading-group .sa-heading {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .sa-top-series__heading-group .sa-copy {
      display: none;
    }

    #shopify-section-{{ section.id }} .sa-top-series__cta {
      flex: 0 0 auto;
    }

    #shopify-section-{{ section.id }} .sa-top-series__wall {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .sa-top-series__empty {
      padding: var(--sa-space-6);
      border: var(--sa-border-hairline);
      border-radius: var(--sa-radius-md);
      background: rgba(16, 16, 16, 0.72);
      color: var(--sa-gallery-stone);
    }

    @media screen and (max-width: 1199px) {
      #shopify-section-{{ section.id }} .sa-top-series__wall {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 899px) {
      #shopify-section-{{ section.id }} .sa-top-series__header-row {
        align-items: start;
        flex-direction: column;
      }

      #shopify-section-{{ section.id }} .sa-top-series__wall {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .sa-top-series__cta {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .sa-top-series--mobile-scroll .sa-top-series__wall,
      #shopify-section-{{ section.id }} .sa-top-series__wall {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        margin-inline: calc(var(--sa-page-gutter) * -1);
        padding-inline: var(--sa-page-gutter);
        padding-block-end: var(--sa-space-2);
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }

      #shopify-section-{{ section.id }} .sa-top-series__wall::-webkit-scrollbar {
        display: none;
      }

      #shopify-section-{{ section.id }} .sa-top-series__card {
        flex: 0 0 min(46vw, 178px);
        scroll-snap-align: start;
      }

      #shopify-section-{{ section.id }} .sa-top-series--mobile-grid .sa-top-series__wall {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        overflow: visible;
        margin-inline: 0;
        padding-inline: 0;
      }

      #shopify-section-{{ section.id }} .sa-top-series--mobile-grid .sa-top-series__card {
        flex: initial;
      }

    }

    @media screen and (max-width: 374px) {
      #shopify-section-{{ section.id }} .sa-top-series--mobile-grid .sa-top-series__wall {
        grid-template-columns: 1fr;
      }
    }

  </style>

  <div class="sa-container">
    <div class="sa-top-series__header">
      <div class="sa-top-series__header-row">
        <div class="sa-top-series__heading-group">
          {% if section_label != blank %}
            <p class="sa-kicker">{{ section_label | escape }}</p>
          {% endif %}

          {% if section_heading != blank %}
            <h2 class="sa-heading" id="sa-top-series-title-{{ section.id }}">{{ section_heading | escape }}</h2>
          {% endif %}

          {% if section_intro != blank %}
            <p class="sa-copy">{{ section_intro }}</p>
          {% endif %}
        </div>

        {% if section.settings.view_all_label != blank and section.settings.view_all_link != blank %}
          <a class="sa-top-series__cta sa-button sa-button--secondary" href="{{ section.settings.view_all_link }}">
            {{ section.settings.view_all_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="sa-top-series__wall" role="list" aria-label="{{ section_heading | escape }}">
        {% for block in section.blocks %}
          {% if forloop.index <= visible_count %}
            {% render 'sa-series-archive-card',
              title: block.settings.series_name,
              url: block.settings.collection_link,
              image: block.settings.image,
              badge: block.settings.badge,
              accent: block.settings.accent_color,
              index: forloop.index,
              meta_text: block.settings.product_count_text,
              accessibility_label: block.settings.accessibility_label,
              shopify_attributes: block.shopify_attributes
            %}
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="sa-top-series__empty" role="status">
        Add series blocks to build the top-performing series archive wall.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SA Top Series",
  "tag": "section",
  "class": "sa-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Archive label",
      "default": "SERIES ARCHIVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Top Performing Series"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Enter through the fandom first. These series paths help customers find the product families and matching sets they might miss in a standard grid."
    },
    {
      "type": "select",
      "id": "visible_count",
      "label": "Visible series",
      "options": [
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" },
        { "value": "10", "label": "10" },
        { "value": "12", "label": "12" }
      ],
      "default": "12"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        { "value": "scroll", "label": "Horizontal scroll" },
        { "value": "grid", "label": "2-column grid" }
      ],
      "default": "grid"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All Series"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "series",
      "name": "Series",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "series_name",
          "label": "Series name",
          "default": "One Piece"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection link"
        },
        {
          "type": "text",
          "id": "product_count_text",
          "label": "Product count text",
          "info": "Enter manually, for example: 42 products. Leave blank if unknown."
        },
        {
          "type": "select",
          "id": "badge",
          "label": "Badge",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "top_seller", "label": "Top Seller" },
            { "value": "trending", "label": "Trending" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "accessibility_label",
          "label": "Accessibility label",
          "info": "Optional. Used as the card link aria-label."
        },
        {
          "type": "select",
          "id": "accent_color",
          "label": "Accent color",
          "options": [
            { "value": "#B3362D", "label": "Relic Red" },
            { "value": "#C45A2A", "label": "Ember Orange" },
            { "value": "#2F5138", "label": "Deep Moss" },
            { "value": "#332A52", "label": "Indigo Smoke" },
            { "value": "#9D7A3C", "label": "Bamboo Amber" }
          ],
          "default": "#B3362D"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SA Top Series",
      "blocks": [
        { "type": "series", "settings": { "series_name": "One Piece", "badge": "top_seller", "accent_color": "#B3362D" } },
        { "type": "series", "settings": { "series_name": "Cowboy Bebop", "badge": "trending", "accent_color": "#C45A2A" } },
        { "type": "series", "settings": { "series_name": "Naruto", "badge": "top_seller", "accent_color": "#2F5138" } },
        { "type": "series", "settings": { "series_name": "Bleach", "badge": "trending", "accent_color": "#332A52" } },
        { "type": "series", "settings": { "series_name": "JJK", "badge": "none", "accent_color": "#9D7A3C" } },
        { "type": "series", "settings": { "series_name": "Dragon Ball Z", "badge": "none", "accent_color": "#B3362D" } },
        { "type": "series", "settings": { "series_name": "Demon Slayer", "badge": "none", "accent_color": "#C45A2A" } },
        { "type": "series", "settings": { "series_name": "Pokemon", "badge": "none", "accent_color": "#2F5138" } },
        { "type": "series", "settings": { "series_name": "Hunter x Hunter", "badge": "none", "accent_color": "#332A52" } },
        { "type": "series", "settings": { "series_name": "Jojo", "badge": "none", "accent_color": "#9D7A3C" } },
        { "type": "series", "settings": { "series_name": "Evangelion", "badge": "none", "accent_color": "#B3362D" } },
        { "type": "series", "settings": { "series_name": "Samurai Champloo", "badge": "none", "accent_color": "#C45A2A" } }
      ]
    }
  ]
}
{% endschema %}
