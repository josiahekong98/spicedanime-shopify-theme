{% liquid
  assign series_title = collection.title | replace: '(Series)', '' | strip
  assign series_filter = series_title | url_encode
  assign accent_color = collection.metafields.custom.accent_color.value | default: section.settings.accent_color | default: '#B3362D'
  assign archive_label = section.settings.archive_label | default: 'Series Archive'
  assign hero_intro = collection.metafields.custom.series_intro.value | default: section.settings.intro
  assign hero_image = collection.metafields.custom.series_hero_image.value | default: section.settings.hero_image | default: collection.image
  assign logo_image = collection.metafields.custom.series_logo.value | default: section.settings.logo_image
  assign product_count = collection.products_count | default: collection.all_products_count
  assign social_proof = section.settings.social_proof

  assign lighter_img = blank
  assign wallet_img = blank
  assign grinder_set_img = blank
  assign tapestry_img = blank
  assign tray_img = blank
  assign jar_img = blank
  assign complete_grinder_set_product = blank
  assign complete_lighter_product = blank
  assign complete_ashtray_product = blank
  assign complete_tray_product = blank
  assign complete_wallet_product = blank
  assign complete_jar_product = blank
  assign complete_tapestry_product = blank
  assign lighter_available = false
  assign wallet_available = false
  assign grinder_set_available = false
  assign tapestry_available = false
  assign tray_available = false
  assign jar_available = false
  assign lighter_count = 0
  assign wallet_count = 0
  assign grinder_set_count = 0
  assign tapestry_count = 0
  assign tray_count = 0
  assign jar_count = 0

  for product in collection.products
    assign ptitle = product.title | downcase
    assign ptype = product.type | downcase
    assign phandle = product.handle | downcase
    assign product_family_text = ptitle | append: ' ' | append: ptype | append: ' ' | append: phandle
    assign is_lighter = false
    assign is_wallet = false
    assign is_grinder_set = false
    assign is_tapestry = false
    assign is_rolling_tray = false
    assign is_stash_jar = false
    assign is_ashtray = false

    if product_family_text contains 'lighter'
      assign is_lighter = true
    endif

    if product_family_text contains 'wallet' or product_family_text contains 'bifold'
      assign is_wallet = true
    endif

    if ptype contains 'grinder set' or product_family_text contains 'grinder set'
      assign is_grinder_set = true
    endif

    if ptype contains 'tapestry'
      unless product_family_text contains 'tote' or product_family_text contains 'pillow' or product_family_text contains 'hoodie'
        assign is_tapestry = true
      endunless
    endif

    if ptype contains 'rolling tray'
      assign is_rolling_tray = true
    elsif product_family_text contains 'rolling tray' and is_grinder_set == false
      assign is_rolling_tray = true
    endif

    if ptype contains 'stash jar' or product_family_text contains 'stash jar'
      assign is_stash_jar = true
    endif

    if ptype contains 'ashtray' or product_family_text contains 'ashtray'
      assign is_ashtray = true
    endif

    if is_lighter
      assign lighter_available = true
      assign lighter_count = lighter_count | plus: 1
      if complete_lighter_product == blank
        assign complete_lighter_product = product
      endif
    endif

    if is_wallet
      assign wallet_available = true
      assign wallet_count = wallet_count | plus: 1
      if complete_wallet_product == blank
        assign complete_wallet_product = product
      endif
    endif

    if is_grinder_set
      assign grinder_set_available = true
      assign grinder_set_count = grinder_set_count | plus: 1
      if complete_grinder_set_product == blank
        assign complete_grinder_set_product = product
      endif
    endif

    if is_tapestry
      assign tapestry_available = true
      assign tapestry_count = tapestry_count | plus: 1
      if complete_tapestry_product == blank
        assign complete_tapestry_product = product
      endif
    endif

    if is_rolling_tray
      assign tray_available = true
      assign tray_count = tray_count | plus: 1
      if complete_tray_product == blank
        assign complete_tray_product = product
      endif
    endif

    if is_stash_jar
      assign jar_available = true
      assign jar_count = jar_count | plus: 1
      if complete_jar_product == blank
        assign complete_jar_product = product
      endif
    endif

    if complete_ashtray_product == blank and is_ashtray
      assign complete_ashtray_product = product
    endif

    if product.featured_image
      if lighter_img == blank and is_lighter
        assign lighter_img = product.featured_image
      endif

      if wallet_img == blank and is_wallet
        assign wallet_img = product.featured_image
      endif

      if grinder_set_img == blank and is_grinder_set
        assign grinder_set_img = product.featured_image
      endif

      if tapestry_img == blank and is_tapestry
        assign tapestry_img = product.featured_image
      endif

      if tray_img == blank and is_rolling_tray
        assign tray_img = product.featured_image
      endif

      if jar_img == blank and is_stash_jar
        assign jar_img = product.featured_image
      endif

    endif
  endfor
%}

<section class="sa-series-page" style="--sa-series-accent: {{ accent_color }};" aria-labelledby="sa-series-title-{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} .sa-series-page {
      width: 100vw;
      position: relative;
      left: 50%;
      margin-left: -50vw;
      background: var(--sa-archive-black, #101010);
      color: var(--sa-museum-ivory, #F4F0E8);
      padding-block-end: 28px;
    }

    #shopify-section-{{ section.id }} .sa-series-page::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: var(--sa-texture-concrete);
      opacity: 0.42;
    }

    #shopify-section-{{ section.id }} .sa-series-page > * {
      position: relative;
    }

    #shopify-section-{{ section.id }} .sa-series-container {
      width: min(1180px, 92vw);
      margin-inline: auto;
    }

    #shopify-section-{{ section.id }} .sa-series-hero {
      min-height: 430px;
      display: grid;
      align-items: end;
      background:
        linear-gradient(90deg, rgba(11, 11, 11, 0.92), rgba(11, 11, 11, 0.46)),
        {% if hero_image %}
          url({{ hero_image | image_url: width: 1800 }})
        {% else %}
          var(--sa-archive-black, #101010)
        {% endif %};
      background-size: cover;
      background-position: center;
      padding-block: clamp(82px, 11vw, 128px) clamp(32px, 5vw, 56px);
    }

    #shopify-section-{{ section.id }} .sa-series-hero__layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(180px, 280px);
      align-items: end;
      gap: clamp(24px, 5vw, 64px);
    }

    #shopify-section-{{ section.id }} .sa-series-hero__content {
      max-width: 680px;
      display: grid;
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__label,
    #shopify-section-{{ section.id }} .sa-series-meta,
    #shopify-section-{{ section.id }} .sa-series-eyebrow {
      color: var(--sa-series-accent);
      font-family: var(--sa-font-archive, monospace);
      font-size: var(--sa-type-label, 11px);
      line-height: 1.2;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__title {
      margin: 0;
      color: var(--sa-museum-ivory, #F4F0E8);
      font-family: var(--sa-font-display, serif);
      font-size: clamp(42px, 8vw, 88px);
      line-height: 0.92;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__title span {
      display: block;
      color: var(--sa-series-accent);
      font-size: 0.42em;
      font-style: italic;
      letter-spacing: 0.04em;
      margin-block-start: 10px;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__intro {
      max-width: 62ch;
      margin: 0;
      color: var(--sa-gallery-stone, #D8D2C7);
      font-size: clamp(15px, 1.25vw, 17px);
      line-height: 1.48;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__actions,
    #shopify-section-{{ section.id }} .sa-series-row__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__actions .sa-button {
      min-height: 42px;
      padding-inline: 22px;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__primary {
      background: rgba(16, 16, 16, 0.34);
      border-color: rgba(244, 240, 232, 0.42);
      color: var(--sa-museum-ivory, #F4F0E8);
      box-shadow: none;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__primary:hover {
      background: rgba(16, 16, 16, 0.48);
      border-color: var(--sa-series-accent);
    }

    #shopify-section-{{ section.id }} .sa-series-meta {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid color-mix(in srgb, var(--sa-series-accent) 62%, transparent);
      background: rgba(16, 16, 16, 0.58);
      padding: 8px 12px;
      color: var(--sa-gallery-stone, #D8D2C7);
    }

    #shopify-section-{{ section.id }} .sa-series-meta__proof {
      color: var(--sa-museum-ivory, #F4F0E8);
    }

    #shopify-section-{{ section.id }} .sa-series-hero__mark {
      min-height: 190px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(244, 240, 232, 0.18);
      background: rgba(16, 16, 16, 0.68);
      box-shadow: 0 20px 48px rgba(0, 0, 0, 0.24);
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__mark img {
      max-width: 100%;
      max-height: 180px;
      object-fit: contain;
    }

    #shopify-section-{{ section.id }} .sa-series-hero__monogram {
      color: var(--sa-series-accent);
      font-family: var(--sa-font-display, serif);
      font-size: clamp(40px, 5vw, 78px);
      line-height: 0.9;
      letter-spacing: 0.08em;
      text-align: center;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-section {
      padding-block-start: clamp(22px, 3vw, 36px);
    }

    #shopify-section-{{ section.id }} .sa-series-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 14px;
      margin-block-end: 12px;
      border-block-end: 1px solid color-mix(in srgb, var(--sa-series-accent) 72%, transparent);
      padding-block-end: 10px;
    }

    #shopify-section-{{ section.id }} .sa-series-head__copy {
      display: grid;
      gap: 8px;
      max-width: 720px;
    }

    #shopify-section-{{ section.id }} .sa-series-title {
      margin: 0;
      color: var(--sa-museum-ivory, #F4F0E8);
      font-family: var(--sa-font-display, serif);
      font-size: clamp(23px, 2.6vw, 34px);
      line-height: 1.06;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-head .sa-series-title {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .sa-series-copy {
      margin: 0;
      color: rgba(216, 210, 199, 0.76);
      font-size: 14px;
      line-height: 1.5;
    }

    #shopify-section-{{ section.id }} .sa-series-view {
      color: var(--sa-series-accent);
      font-family: var(--sa-font-archive, monospace);
      font-size: var(--sa-type-label, 11px);
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .sa-series-family-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card {
      min-height: 258px;
      display: grid;
      grid-template-rows: 1fr auto;
      overflow: hidden;
      border: var(--sa-border-hairline, 1px solid rgba(244, 240, 232, 0.16));
      border-radius: var(--sa-radius-md, 8px);
      background: var(--sa-surface-panel, #181818);
      color: var(--sa-museum-ivory, #F4F0E8);
      text-decoration: none;
      box-shadow: var(--sa-shadow-card, 0 18px 34px rgba(0, 0, 0, 0.28));
      transition: transform var(--sa-motion-standard, 220ms ease), border-color var(--sa-motion-standard, 220ms ease), box-shadow var(--sa-motion-standard, 220ms ease);
    }

    #shopify-section-{{ section.id }} .sa-series-family-card:hover {
      transform: translateY(-2px);
      border-color: var(--sa-series-accent);
      box-shadow: var(--sa-shadow-card, 0 18px 34px rgba(0, 0, 0, 0.28)), 0 0 0 1px color-mix(in srgb, var(--sa-series-accent) 34%, transparent);
    }

    #shopify-section-{{ section.id }} .sa-series-family-card[aria-disabled="true"] {
      opacity: 0.78;
      pointer-events: none;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card--quiet {
      background: linear-gradient(135deg, rgba(244, 240, 232, 0.04), rgba(179, 54, 45, 0.05)), var(--sa-surface-panel, #181818);
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__media {
      position: relative;
      min-height: 176px;
      display: grid;
      place-items: center;
      background: radial-gradient(circle, rgba(244, 240, 232, 0.1), transparent 58%), var(--sa-texture-concrete), #101010;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__media::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(11, 11, 11, 0) 36%, rgba(11, 11, 11, 0.74)), var(--sa-texture-concrete);
      opacity: 0.78;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__media img {
      width: 100%;
      height: 100%;
      min-height: 176px;
      object-fit: cover;
      display: block;
      opacity: 0.9;
      transform: scale(1.01);
      transition: transform var(--sa-motion-standard, 220ms ease), opacity var(--sa-motion-standard, 220ms ease);
    }

    #shopify-section-{{ section.id }} .sa-series-family-card:hover .sa-series-family-card__media img {
      opacity: 0.98;
      transform: scale(1.035);
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__fallback {
      position: relative;
      z-index: 1;
      color: var(--sa-gallery-stone, #D8D2C7);
      font-family: var(--sa-font-archive, monospace);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      opacity: 0.72;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__label {
      min-height: 72px;
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      background: color-mix(in srgb, var(--sa-concrete-charcoal, #1C1B19) 88%, black);
      font-weight: 800;
      font-size: clamp(18px, 1.6vw, 24px);
      font-family: var(--sa-font-display, serif);
      line-height: 1.2;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__count {
      color: var(--sa-series-accent);
      font-family: var(--sa-font-archive, monospace);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      line-height: 1.25;
      text-align: right;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__label::after {
      content: none;
      color: var(--sa-series-accent);
      font-size: 18px;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .sa-series-family-card__title {
      display: block;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .sa-series-products {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .sa-series-products--compact {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .sa-series-product {
      display: grid;
      grid-template-rows: auto 1fr;
      background: var(--sa-surface-panel, #181818);
      border: var(--sa-border-hairline, 1px solid rgba(244, 240, 232, 0.14));
      border-radius: var(--sa-radius-md, 8px);
      color: var(--sa-museum-ivory, #F4F0E8);
      text-decoration: none;
      overflow: hidden;
      box-shadow: var(--sa-shadow-card, 0 18px 34px rgba(0, 0, 0, 0.28));
      transition: transform var(--sa-motion-standard, 220ms ease), border-color var(--sa-motion-standard, 220ms ease), box-shadow var(--sa-motion-standard, 220ms ease);
    }

    #shopify-section-{{ section.id }} .sa-series-product:hover {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--sa-series-accent) 72%, rgba(244, 240, 232, 0.14));
      box-shadow: var(--sa-shadow-card, 0 18px 34px rgba(0, 0, 0, 0.28)), 0 0 0 1px color-mix(in srgb, var(--sa-series-accent) 26%, transparent);
    }

    #shopify-section-{{ section.id }} .sa-series-product__media {
      position: relative;
      aspect-ratio: 1 / 1;
      background: #101010;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .sa-series-product__media::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(11, 11, 11, 0) 42%, rgba(11, 11, 11, 0.58)), var(--sa-texture-concrete);
      opacity: 0.62;
    }

    #shopify-section-{{ section.id }} .sa-series-product__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      opacity: 0.9;
      transform: scale(1.01);
      transition: transform var(--sa-motion-standard, 220ms ease), opacity var(--sa-motion-standard, 220ms ease);
    }

    #shopify-section-{{ section.id }} .sa-series-product:hover .sa-series-product__media img {
      opacity: 0.98;
      transform: scale(1.035);
    }

    #shopify-section-{{ section.id }} .sa-series-product__fallback {
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      color: var(--sa-gallery-stone, #D8D2C7);
      font-family: var(--sa-font-archive, monospace);
      font-size: 22px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-product__content {
      display: grid;
      gap: 7px;
      padding: 13px;
      background: color-mix(in srgb, var(--sa-concrete-charcoal, #1C1B19) 88%, black);
    }

    #shopify-section-{{ section.id }} .sa-series-product__badge {
      position: absolute;
      inset: var(--sa-space-3, 12px) var(--sa-space-3, 12px) auto auto;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 5px 10px;
      border: 1px solid transparent;
      border-radius: var(--sa-radius-xs, 3px);
      background: var(--sa-relic-red, #B3362D);
      color: var(--sa-museum-ivory, #F4F0E8);
      font-family: var(--sa-font-archive, monospace);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.12em;
      line-height: 1;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-product__type {
      color: var(--sa-series-accent);
      font-family: var(--sa-font-archive, monospace);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-product__title {
      margin: 0;
      color: var(--sa-museum-ivory, #F4F0E8);
      font-family: var(--sa-font-display, serif);
      font-size: clamp(16px, 1.45vw, 22px);
      line-height: 1.08;
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    #shopify-section-{{ section.id }} .sa-series-product__price {
      margin: 0;
      color: rgba(244, 240, 232, 0.74);
      font-family: var(--sa-font-archive, monospace);
      font-size: 11px;
      letter-spacing: 0.1em;
      line-height: 1.3;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .sa-series-empty {
      border: 1px solid rgba(244, 240, 232, 0.16);
      background: #181818;
      color: var(--sa-gallery-stone, #D8D2C7);
      padding: 16px;
      font-size: 13px;
      line-height: 1.45;
    }

    #shopify-section-{{ section.id }} .sa-series-related-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .sa-series-related-card {
      min-height: 260px;
      position: relative;
      display: grid;
      align-items: end;
      overflow: hidden;
      border: var(--sa-border-hairline, 1px solid rgba(244, 240, 232, 0.14));
      border-radius: var(--sa-radius-md, 8px);
      background: var(--sa-surface-panel, #181818);
      color: #fff;
      text-decoration: none;
      box-shadow: var(--sa-shadow-card, 0 18px 34px rgba(0, 0, 0, 0.28));
    }

    #shopify-section-{{ section.id }} .sa-series-related-card img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.74);
    }

    #shopify-section-{{ section.id }} .sa-series-related-card__label {
      position: relative;
      padding: 14px;
      color: #fff;
      font-family: var(--sa-font-display, serif);
      font-size: 22px;
      line-height: 1;
      text-transform: uppercase;
      text-shadow: 0 2px 12px rgba(0, 0, 0, 0.82);
    }

    #shopify-section-{{ section.id }} .sa-series-seo {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
      gap: 22px;
      align-items: start;
    }

    #shopify-section-{{ section.id }} .sa-series-seo__body,
    #shopify-section-{{ section.id }} .sa-series-faq {
      border: 1px solid rgba(244, 240, 232, 0.16);
      background: #181818;
      padding: 18px;
    }

    #shopify-section-{{ section.id }} .sa-series-seo__body {
      color: #ddd;
      font-size: 14px;
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .sa-series-faq {
      display: grid;
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .sa-series-faq details {
      border-block-end: 1px solid rgba(244, 240, 232, 0.12);
      padding-block-end: 10px;
    }

    #shopify-section-{{ section.id }} .sa-series-faq details:last-child {
      border-block-end: 0;
      padding-block-end: 0;
    }

    #shopify-section-{{ section.id }} .sa-series-faq summary {
      cursor: pointer;
      color: #fff;
      font-size: 13px;
      font-weight: 800;
      list-style: none;
    }

    #shopify-section-{{ section.id }} .sa-series-faq summary::-webkit-details-marker {
      display: none;
    }

    #shopify-section-{{ section.id }} .sa-series-faq p {
      margin: 10px 0 0;
      color: #cfcfcf;
      font-size: 12px;
      line-height: 1.45;
    }

    @media screen and (max-width: 1100px) {
      #shopify-section-{{ section.id }} .sa-series-family-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .sa-series-products,
      #shopify-section-{{ section.id }} .sa-series-related-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .sa-series-hero {
        min-height: 360px;
        padding-block: 64px 24px;
      }

      #shopify-section-{{ section.id }} .sa-series-page {
        padding-block-end: 22px;
      }

      #shopify-section-{{ section.id }} .sa-series-section {
        padding-block-start: 24px;
      }

      #shopify-section-{{ section.id }} .sa-series-hero__layout,
      #shopify-section-{{ section.id }} .sa-series-seo {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .sa-series-hero__mark {
        display: none;
      }

      #shopify-section-{{ section.id }} .sa-series-head {
        align-items: start;
        flex-direction: column;
        gap: 8px;
        margin-block-end: 10px;
        padding-block-end: 9px;
      }

      #shopify-section-{{ section.id }} .sa-series-family-grid,
      #shopify-section-{{ section.id }} .sa-series-products,
      #shopify-section-{{ section.id }} .sa-series-products--compact,
      #shopify-section-{{ section.id }} .sa-series-related-grid {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        margin-inline: -4vw;
        padding-inline: 4vw;
        padding-block-end: 6px;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }

      #shopify-section-{{ section.id }} .sa-series-family-grid::-webkit-scrollbar,
      #shopify-section-{{ section.id }} .sa-series-products::-webkit-scrollbar,
      #shopify-section-{{ section.id }} .sa-series-related-grid::-webkit-scrollbar {
        display: none;
      }

      #shopify-section-{{ section.id }} .sa-series-family-card {
        flex: 0 0 min(56vw, 228px);
        min-height: 218px;
        scroll-snap-align: start;
      }

      #shopify-section-{{ section.id }} .sa-series-product {
        flex: 0 0 min(54vw, 220px);
        scroll-snap-align: start;
      }

      #shopify-section-{{ section.id }} .sa-series-related-card {
        flex: 0 0 min(58vw, 230px);
        scroll-snap-align: start;
      }

      #shopify-section-{{ section.id }} .sa-series-family-card__media,
      #shopify-section-{{ section.id }} .sa-series-family-card__media img {
        min-height: 146px;
      }

      #shopify-section-{{ section.id }} .sa-series-hero__title {
        font-size: clamp(40px, 13vw, 58px);
      }

      #shopify-section-{{ section.id }} .sa-series-title {
        font-size: clamp(26px, 8vw, 38px);
      }

      #shopify-section-{{ section.id }} .sa-series-hero__actions .sa-button {
        width: 100%;
        min-height: 48px;
      }
    }
  </style>

  <div class="sa-series-hero">
    <div class="sa-series-container">
      <div class="sa-series-hero__layout">
        <div class="sa-series-hero__content">
          {% if archive_label != blank %}
            <p class="sa-series-hero__label">{{ archive_label | escape }}</p>
          {% endif %}

          <h1 class="sa-series-hero__title" id="sa-series-title-{{ section.id }}">
            {{ series_title | escape }}
            <span>Anime Accessories</span>
          </h1>

          <p class="sa-series-hero__intro">
            {% if hero_intro != blank %}
              {{ hero_intro | strip_html | escape }}
            {% else %}
              Collectible accessories for this fandom. Shop one piece or build the full setup.
            {% endif %}
          </p>

          <div class="sa-series-hero__actions">
            <a class="sa-button sa-button--secondary sa-series-hero__primary" href="#ProductGridContainer">Shop All Products</a>
            <span class="sa-series-meta">
              <span>{{ product_count }} {% if product_count == 1 %}Product{% else %}Products{% endif %}</span>
              {% if social_proof != blank %}
                <span aria-hidden="true">|</span>
                <span class="sa-series-meta__proof">{{ social_proof | escape }}</span>
              {% endif %}
            </span>
          </div>
        </div>

        <div class="sa-series-hero__mark" aria-hidden="true">
          {% if logo_image %}
            <img src="{{ logo_image | image_url: width: 560 }}" alt="">
          {% else %}
            <div class="sa-series-hero__monogram">{{ series_title | slice: 0, 2 | upcase }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="sa-series-container">
    <section class="sa-series-section" aria-labelledby="sa-series-best-title-{{ section.id }}">
      <div class="sa-series-head">
        <div class="sa-series-head__copy">
          <p class="sa-series-eyebrow">Best Sellers</p>
          <h2 class="sa-series-title" id="sa-series-best-title-{{ section.id }}">Top {{ series_title | escape }} Picks</h2>
          <p class="sa-series-copy">Fan-favorite pieces from this series.</p>
        </div>
        <a class="sa-series-view" href="{{ collection.url }}?sort_by=best-selling#ProductGridContainer">Sort Best Selling -></a>
      </div>

      {% if collection.products_count > 0 %}
        <div class="sa-series-products" role="list" aria-label="Best selling {{ series_title | escape }} products">
          {% for product in collection.products limit: section.settings.best_seller_limit %}
            {% if forloop.first %}
              {% render 'sa-series-product-card', product: product, badge: '#1 Pick' %}
            {% else %}
              {% render 'sa-series-product-card', product: product %}
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="sa-series-empty" role="status">Best sellers will appear here when this series collection has products.</div>
      {% endif %}
    </section>

    {% if section.settings.show_complete_set %}
      <section class="sa-series-section" aria-labelledby="sa-series-set-title-{{ section.id }}">
        <div class="sa-series-head">
          <div class="sa-series-head__copy">
            <p class="sa-series-eyebrow">Complete The Set</p>
            <h2 class="sa-series-title" id="sa-series-set-title-{{ section.id }}">Complete Your {{ series_title | escape }} Collection</h2>
            <p class="sa-series-copy">Mix product types to build your setup and unlock bundle savings.</p>
          </div>
        </div>

        {% liquid
          assign complete_has_products = false
          if section.settings.complete_include_grinder_set and complete_grinder_set_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_lighter and complete_lighter_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_ashtray and complete_ashtray_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_rolling_tray and complete_tray_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_wallet and complete_wallet_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_stash_jar and complete_jar_product != blank
            assign complete_has_products = true
          endif
          if section.settings.complete_include_tapestry and complete_tapestry_product != blank
            assign complete_has_products = true
          endif
        %}

        {% capture complete_set_products %}
          {% assign rendered_setup_handles = '' %}
          {% if section.settings.complete_include_grinder_set and complete_grinder_set_product != blank %}
            {% assign setup_key = '|' | append: complete_grinder_set_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_grinder_set_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_lighter and complete_lighter_product != blank %}
            {% assign setup_key = '|' | append: complete_lighter_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_lighter_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_ashtray and complete_ashtray_product != blank %}
            {% assign setup_key = '|' | append: complete_ashtray_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_ashtray_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_rolling_tray and complete_tray_product != blank %}
            {% assign setup_key = '|' | append: complete_tray_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_tray_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_wallet and complete_wallet_product != blank %}
            {% assign setup_key = '|' | append: complete_wallet_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_wallet_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_stash_jar and complete_jar_product != blank %}
            {% assign setup_key = '|' | append: complete_jar_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_jar_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
          {% if section.settings.complete_include_tapestry and complete_tapestry_product != blank %}
            {% assign setup_key = '|' | append: complete_tapestry_product.handle | append: '|' %}
            {% unless rendered_setup_handles contains setup_key %}
              {% render 'sa-series-product-card', product: complete_tapestry_product %}
              {% assign rendered_setup_handles = rendered_setup_handles | append: setup_key %}
            {% endunless %}
          {% endif %}
        {% endcapture %}

        {% if complete_has_products %}
          <div class="sa-series-products" role="list" aria-label="Complete the set products for {{ series_title | escape }}">
            {{ complete_set_products }}
          </div>
        {% else %}
          <div class="sa-series-empty" role="status">Choose product types in the Theme Editor, or add matching products to this series.</div>
        {% endif %}
      </section>
    {% endif %}

    <section class="sa-series-section" aria-labelledby="sa-series-family-title-{{ section.id }}">
        <div class="sa-series-head">
          <div class="sa-series-head__copy">
          <p class="sa-series-eyebrow">Shop By Product</p>
          <h2 class="sa-series-title" id="sa-series-family-title-{{ section.id }}">Shop By Product</h2>
        </div>
      </div>

      <div class="sa-series-family-grid" role="list">
        {% render 'sa-series-family-card', title: 'Tapestries', count: tapestry_count, image: tapestry_img, available: tapestry_available, url: section.settings.tapestries_url, fallback_url: '/collections/all-tapestries', series_filter: series_filter %}
        {% render 'sa-series-family-card', title: 'Wallets', count: wallet_count, image: wallet_img, available: wallet_available, url: section.settings.wallets_url, fallback_url: '/collections/wallets-category', series_filter: series_filter %}
        {% render 'sa-series-family-card', title: 'Lighters', count: lighter_count, image: lighter_img, available: lighter_available, url: section.settings.lighters_url, fallback_url: '/collections/all-products-lighters', series_filter: series_filter %}
        {% render 'sa-series-family-card', title: 'Grinder Sets', count: grinder_set_count, image: grinder_set_img, available: grinder_set_available, url: section.settings.grinder_sets_url, fallback_url: '/collections/herb-grinders', series_filter: series_filter %}
        {% render 'sa-series-family-card', title: 'Rolling Trays', count: tray_count, image: tray_img, available: tray_available, url: section.settings.rolling_trays_url, fallback_url: '/collections/all-rolling-trays', series_filter: series_filter %}
        {% render 'sa-series-family-card', title: 'Stash Jars', count: jar_count, image: jar_img, available: jar_available, url: section.settings.stash_jars_url, fallback_url: '/collections/all-products-stash-jars', series_filter: series_filter %}
      </div>
    </section>

    <section class="sa-series-section" aria-labelledby="sa-series-more-title-{{ section.id }}">
      <div class="sa-series-head">
        <div class="sa-series-head__copy">
          <p class="sa-series-eyebrow">Collection Wall</p>
          <h2 class="sa-series-title" id="sa-series-more-title-{{ section.id }}">Browse The {{ series_title | escape }} Collection</h2>
          <p class="sa-series-copy">Every {{ series_title | escape }} design in one place. Browse everything.</p>
        </div>
      </div>

      {% if collection.products_count > section.settings.best_seller_limit %}
        <div class="sa-series-products sa-series-products--compact" role="list" aria-label="More {{ series_title | escape }} products">
          {% for product in collection.products offset: section.settings.best_seller_limit limit: section.settings.more_from_limit %}
            {% render 'sa-series-product-card', product: product %}
          {% endfor %}
        </div>
      {% else %}
        <div class="sa-series-empty" role="status">More products will appear here when this series has enough items beyond the best-seller preview.</div>
      {% endif %}

      <div class="sa-series-row__actions" style="margin-block-start: 12px;">
        <a class="sa-button sa-button--secondary" href="#ProductGridContainer">Browse All {{ product_count }} {% if product_count == 1 %}Product{% else %}Products{% endif %}</a>
      </div>
    </section>

    {% if section.blocks.size > 0 or request.design_mode %}
      <section class="sa-series-section" aria-labelledby="sa-series-related-title-{{ section.id }}">
        <div class="sa-series-head">
          <div class="sa-series-head__copy">
            <p class="sa-series-eyebrow">Related Series</p>
            <h2 class="sa-series-title" id="sa-series-related-title-{{ section.id }}">Nearby Archive Rooms</h2>
          </div>
        </div>

        {% if section.blocks.size > 0 %}
          <div class="sa-series-related-grid" role="list" aria-label="Related series collections">
            {% for block in section.blocks %}
              {% assign related_collection = block.settings.collection %}
              {% assign related_title = block.settings.title | default: related_collection.title | replace: '(Series)', '' | strip %}
              {% assign related_image = block.settings.image | default: related_collection.image | default: related_collection.products.first.featured_image %}
              {% if related_collection != blank %}
                <a class="sa-series-related-card" href="{{ related_collection.url }}" role="listitem" {{ block.shopify_attributes }}>
                  {% if related_image != blank %}
                    <img src="{{ related_image | image_url: width: 700 }}" alt="{{ related_title | escape }}">
                  {% endif %}
                  <span class="sa-series-related-card__label">{{ related_title | escape }}</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="sa-series-empty" role="status">Add related series blocks in the Theme Editor to connect this fandom to nearby archive rooms.</div>
        {% endif %}
      </section>
    {% endif %}

    {% if collection.description != blank %}
      <section class="sa-series-section" aria-labelledby="sa-series-seo-title-{{ section.id }}">
        <div class="sa-series-head">
          <div class="sa-series-head__copy">
            <p class="sa-series-eyebrow">Series Notes</p>
            <h2 class="sa-series-title" id="sa-series-seo-title-{{ section.id }}">About This Archive</h2>
          </div>
        </div>

        <div class="sa-series-seo">
          <div class="sa-series-seo__body">
            {{ collection.description }}
          </div>

          <div class="sa-series-faq">
            <details>
              <summary>What products are in the {{ series_title | escape }} collection?</summary>
              <p>This archive can include lighters, wallets, grinder sets, tapestries, rolling trays, stash jars, and related collectible accessories.</p>
            </details>
            <details>
              <summary>Can I filter this series by product type?</summary>
              <p>Yes. Use the product-family shortcuts above or the native collection filters in the full grid below.</p>
            </details>
            <details>
              <summary>Do matching setup products appear here?</summary>
              <p>When matching-set or setup products exist, they appear in the Complete the Set row and in the full product grid.</p>
            </details>
          </div>
        </div>
      </section>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Series Collection Landing",
  "settings": [
    {
      "type": "text",
      "id": "archive_label",
      "label": "Archive label",
      "default": "Series Archive"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Fallback intro",
      "default": "Collectible accessories for this fandom. Shop one piece or build the full setup."
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof line",
      "default": "Loved by anime fans"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Fallback hero image"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Fallback series logo"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Fallback accent color",
      "default": "#B3362D"
    },
    {
      "type": "range",
      "id": "best_seller_limit",
      "label": "Best seller products",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "more_from_limit",
      "label": "Browse collection products",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_complete_set",
      "label": "Show Complete the Set row",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "complete_include_grinder_set",
      "label": "Complete the Set: Grinder Sets",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "complete_include_lighter",
      "label": "Complete the Set: Lighters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "complete_include_ashtray",
      "label": "Complete the Set: Ashtrays",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "complete_include_rolling_tray",
      "label": "Complete the Set: Rolling Trays",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "complete_include_wallet",
      "label": "Complete the Set: Wallets",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "complete_include_stash_jar",
      "label": "Complete the Set: Stash Jars",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "complete_include_tapestry",
      "label": "Complete the Set: Tapestries",
      "default": false
    },
    {
      "type": "url",
      "id": "lighters_url",
      "label": "Lighters collection link"
    },
    {
      "type": "url",
      "id": "wallets_url",
      "label": "Wallets collection link"
    },
    {
      "type": "url",
      "id": "grinder_sets_url",
      "label": "Grinder Sets collection link",
      "info": "Defaults to /collections/herb-grinders."
    },
    {
      "type": "url",
      "id": "tapestries_url",
      "label": "Tapestries collection link"
    },
    {
      "type": "url",
      "id": "rolling_trays_url",
      "label": "Rolling Trays collection link"
    },
    {
      "type": "url",
      "id": "stash_jars_url",
      "label": "Stash Jars collection link"
    }
  ],
  "blocks": [
    {
      "type": "related_series",
      "name": "Related series",
      "limit": 8,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Series collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title override"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Series Collection Landing"
    }
  ]
}
{% endschema %}
