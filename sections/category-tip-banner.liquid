{% if collection and collection.title contains '(category)' %}
<section id="shopify-section-{{ section.id }}" class="category-tip-banner">
  <div class="category-tip-banner__inner">
    <div class="category-tip-banner__box">
      <div class="category-tip-banner__content">

  <div class="category-tip-banner__text">
          {% if collection.metafields.custom.category_tip_heading != blank %}
            <div class="category-tip-banner__heading-row">
              <span class="category-tip-banner__heading">
                {{ collection.metafields.custom.category_tip_heading }}
              </span>
            </div>
          {% endif %}

          <div class="category-tip-banner__body">
  <span class="category-tip-banner__icon">💡</span>
  <span class="category-tip-banner__label">Tip:</span>
  <span class="category-tip-banner__desc">
              {{ collection.metafields.custom.category_tip | default: 'TEST TIP BANNER' }}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
#shopify-section-{{ section.id }}{
  background:#1F1F1F;
  margin-bottom:0;
}

/* container */
#shopify-section-{{ section.id }} .category-tip-banner__inner{
  max-width:1200px;
  margin:0 auto;
  padding:14px 14px 6px;
}

/* tip box */
#shopify-section-{{ section.id }} .category-tip-banner__box{
  position:relative;
  overflow:hidden;
  border-radius:14px;
  padding:14px 18px;
  background:
    radial-gradient(circle at 50% 115%, rgba(224,184,76,.28), rgba(224,184,76,0) 28%),
    radial-gradient(circle at 50% 50%, rgba(255,255,255,.03), rgba(255,255,255,0) 60%),
    linear-gradient(
      to right,
      rgba(255,255,255,0.035),
      rgba(255,255,255,0.055),
      rgba(255,255,255,0.035)
    );
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.05),
    0 10px 24px rgba(0,0,0,.16);
}

/* subtle grain / glow overlay */
#shopify-section-{{ section.id }} .category-tip-banner__box::before{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,.05) 0, rgba(255,255,255,0) 18%),
    radial-gradient(circle at 80% 20%, rgba(224,184,76,.06) 0, rgba(224,184,76,0) 20%),
    radial-gradient(circle at 50% 100%, rgba(224,184,76,.18) 0, rgba(224,184,76,0) 26%);
  opacity:.9;
}

/* content layout */
#shopify-section-{{ section.id }} .category-tip-banner__content{
  position:relative;
  z-index:1;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  text-align:center;
}

/* icon */
#shopify-section-{{ section.id }} .category-tip-banner__icon{
  font-size:16px;
  line-height:1;
  transform:translateY(1px);
  transform:translateX(6px);
}

/* text wrapper */
#shopify-section-{{ section.id }} .category-tip-banner__text{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:#d7d7d7;
}

/* top heading row */
#shopify-section-{{ section.id }} .category-tip-banner__heading-row{
  margin-bottom:2px;
  line-height:1.1;
}

/* heading */
#shopify-section-{{ section.id }} .category-tip-banner__heading{
  color:#e0b84c;
  font-weight:700;
  font-size:17px;
  letter-spacing:-0.01em;
}

/* tip line */
#shopify-section-{{ section.id }} .category-tip-banner__body{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  font-size:13px;
  line-height:1.4;
  color:#d7d7d7;
}

/* Tip: label */
#shopify-section-{{ section.id }} .category-tip-banner__label{
  color:#e0b84c;
  font-weight:700;
  font-size:15px;
  margin-right:6px;
}

/* main description */
#shopify-section-{{ section.id }} .category-tip-banner__desc{
  color:#e7e7e7;
}

/* mobile */
@media(max-width:749px){
  #shopify-section-{{ section.id }} .category-tip-banner__inner{
    padding:12px 12px 4px;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__box{
    padding:12px 14px;
    border-radius:12px;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__content{
    gap:6px;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__icon{
    font-size:18px;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__heading{
    font-size:15px;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__body{
    font-size:12px;
    line-height:1.38;
  }

  #shopify-section-{{ section.id }} .category-tip-banner__label{
    font-size:14px;
    margin-right:5px;
  }
}
</style>

{% endif %}

{% schema %}
{
  "name": "Category Tip Banner",
  "settings": [],
  "presets": [
    {
      "name": "Category Tip Banner"
    }
  ]
}
{% endschema %}