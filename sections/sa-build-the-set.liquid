{{ 'sa-build-the-set.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sa-build-the-set.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign valid_series_count = 0
  for block in section.blocks
    assign has_setup = false
    if block.settings.lighter_tin_products != blank or block.settings.lighter_tin_link != blank
      assign has_setup = true
    elsif block.settings.grinder_jar_tray_products != blank or block.settings.grinder_jar_tray_link != blank
      assign has_setup = true
    elsif block.settings.full_smoke_products != blank or block.settings.full_smoke_link != blank
      assign has_setup = true
    elsif block.settings.room_decor_products != blank or block.settings.room_decor_link != blank
      assign has_setup = true
    elsif block.settings.edc_products != blank or block.settings.edc_link != blank
      assign has_setup = true
    endif

    if block.settings.series_title != blank and has_setup
      assign valid_series_count = valid_series_count | plus: 1
    endif
  endfor
-%}

<sa-build-the-set
  class="sa-build-the-set"
  data-sa-build-set-root
  data-section-id="{{ section.id }}"
  data-money-format="{{ shop.money_format | strip_html | escape }}"
>
  <section class="sa-build-the-set__section" aria-labelledby="sa-build-set-title-{{ section.id }}">
    <div class="sa-build-the-set__inner">
      <header class="sa-build-the-set__hero">
        {%- if section.settings.eyebrow != blank -%}
          <p class="sa-build-the-set__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h1 class="sa-build-the-set__title" id="sa-build-set-title-{{ section.id }}">
          {{ section.settings.heading | escape }}
        </h1>
        {%- if section.settings.intro != blank -%}
          <div class="sa-build-the-set__intro rte">{{ section.settings.intro }}</div>
        {%- endif -%}
      </header>

      {%- if valid_series_count > 0 -%}
        <div class="sa-build-the-set__step sa-build-the-set__step--series">
          <div class="sa-build-the-set__step-heading">
            <span class="sa-build-the-set__step-number">{{ section.settings.series_step_label | escape }}</span>
            <h2>{{ section.settings.series_heading | escape }}</h2>
          </div>

          <div
            class="sa-build-the-set__series-controls"
            data-sa-build-set-series-controls
            aria-label="{{ section.settings.series_heading | escape }}"
          >
            {%- assign valid_series_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- liquid
                assign has_setup = false
                if block.settings.lighter_tin_products != blank or block.settings.lighter_tin_link != blank
                  assign has_setup = true
                elsif block.settings.grinder_jar_tray_products != blank or block.settings.grinder_jar_tray_link != blank
                  assign has_setup = true
                elsif block.settings.full_smoke_products != blank or block.settings.full_smoke_link != blank
                  assign has_setup = true
                elsif block.settings.room_decor_products != blank or block.settings.room_decor_link != blank
                  assign has_setup = true
                elsif block.settings.edc_products != blank or block.settings.edc_link != blank
                  assign has_setup = true
                endif

                unless block.settings.series_title != blank and has_setup
                  continue
                endunless

                assign valid_series_index = valid_series_index | plus: 1
                assign is_active_series = false
                if valid_series_index == 1
                  assign is_active_series = true
                endif
                assign series_key = block.id
                assign series_label = block.settings.accessibility_label | default: block.settings.series_title
              -%}
              <button
                class="sa-build-the-set__series-button{% if is_active_series %} is-active{% endif %}"
                type="button"
                data-sa-build-set-series
                data-series-key="{{ series_key }}"
                aria-controls="sa-build-set-series-panel-{{ section.id }}-{{ block.id }}"
                aria-pressed="{% if is_active_series %}true{% else %}false{% endif %}"
                aria-label="{{ series_label | escape }}"
                style="--sa-build-set-accent: {{ block.settings.accent }};"
              >
                <span class="sa-build-the-set__series-marker" aria-hidden="true"></span>
                <span>{{ block.settings.series_title | escape }}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>

        <div class="sa-build-the-set__series-panels">
          {%- assign valid_series_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign has_setup = false
              if block.settings.lighter_tin_products != blank or block.settings.lighter_tin_link != blank
                assign has_setup = true
              elsif block.settings.grinder_jar_tray_products != blank or block.settings.grinder_jar_tray_link != blank
                assign has_setup = true
              elsif block.settings.full_smoke_products != blank or block.settings.full_smoke_link != blank
                assign has_setup = true
              elsif block.settings.room_decor_products != blank or block.settings.room_decor_link != blank
                assign has_setup = true
              elsif block.settings.edc_products != blank or block.settings.edc_link != blank
                assign has_setup = true
              endif

              unless block.settings.series_title != blank and has_setup
                continue
              endunless

              assign valid_series_index = valid_series_index | plus: 1
              assign is_active_series = false
              if valid_series_index == 1
                assign is_active_series = true
              endif
              assign series_key = block.id
            -%}

            <section
              class="sa-build-the-set__series-panel"
              id="sa-build-set-series-panel-{{ section.id }}-{{ block.id }}"
              data-sa-build-set-series-panel
              data-series-key="{{ series_key }}"
              data-series-title="{{ block.settings.series_title | escape }}"
              aria-hidden="{% if is_active_series %}false{% else %}true{% endif %}"
              style="--sa-build-set-accent: {{ block.settings.accent }};"
              {% unless is_active_series %}hidden{% endunless %}
              {{ block.shopify_attributes }}
            >
              <div class="sa-build-the-set__series-context{% if block.settings.series_image != blank %} sa-build-the-set__series-context--with-media{% endif %}">
                {%- if block.settings.series_image != blank -%}
                  <div class="sa-build-the-set__series-media">
                    {{ block.settings.series_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        widths: '320, 480, 720, 960, 1200',
                        sizes: '(min-width: 990px) 38vw, 100vw',
                        alt: block.settings.series_title
                    }}
                  </div>
                {%- endif -%}
                <div class="sa-build-the-set__series-copy">
                  <p class="sa-build-the-set__archive-label">{{ section.settings.series_context_label | escape }}</p>
                  <p class="sa-build-the-set__series-title">{{ block.settings.series_title | escape }}</p>
                  {%- if block.settings.description != blank -%}
                    <div class="sa-build-the-set__series-description rte">{{ block.settings.description }}</div>
                  {%- endif -%}
                  {%- if block.settings.series_collection != blank -%}
                    <a class="sa-build-the-set__text-link" href="{{ block.settings.series_collection.url }}">
                      {{ section.settings.series_collection_label | escape }}
                    </a>
                  {%- endif -%}
                </div>
              </div>

              <div class="sa-build-the-set__step sa-build-the-set__step--setup">
                <div class="sa-build-the-set__step-heading">
                  <span class="sa-build-the-set__step-number">{{ section.settings.setup_step_label | escape }}</span>
                  <h2>{{ section.settings.setup_heading | escape }}</h2>
                </div>

                <div
                  class="sa-build-the-set__setup-controls"
                  data-sa-build-set-setup-controls
                  aria-label="{{ section.settings.setup_heading | escape }}"
                >
                  {%- assign setup_keys = 'lighter_tin,grinder_jar_tray,full_smoke,room_decor,edc' | split: ',' -%}
                  {%- assign valid_setup_index = 0 -%}
                  {%- for setup_key in setup_keys -%}
                    {%- liquid
                      case setup_key
                        when 'lighter_tin'
                          assign setup_products = block.settings.lighter_tin_products
                          assign setup_link = block.settings.lighter_tin_link
                          assign setup_label = section.settings.lighter_tin_label
                        when 'grinder_jar_tray'
                          assign setup_products = block.settings.grinder_jar_tray_products
                          assign setup_link = block.settings.grinder_jar_tray_link
                          assign setup_label = section.settings.grinder_jar_tray_label
                        when 'full_smoke'
                          assign setup_products = block.settings.full_smoke_products
                          assign setup_link = block.settings.full_smoke_link
                          assign setup_label = section.settings.full_smoke_label
                        when 'room_decor'
                          assign setup_products = block.settings.room_decor_products
                          assign setup_link = block.settings.room_decor_link
                          assign setup_label = section.settings.room_decor_label
                        when 'edc'
                          assign setup_products = block.settings.edc_products
                          assign setup_link = block.settings.edc_link
                          assign setup_label = section.settings.edc_label
                      endcase

                      if setup_products == blank and setup_link == blank
                        continue
                      endif

                      assign valid_setup_index = valid_setup_index | plus: 1
                      assign is_active_setup = false
                      if valid_setup_index == 1
                        assign is_active_setup = true
                      endif
                    -%}
                    <button
                      class="sa-build-the-set__setup-button{% if is_active_setup %} is-active{% endif %}"
                      type="button"
                      data-sa-build-set-setup
                      data-setup-key="{{ setup_key }}"
                      aria-controls="sa-build-set-setup-panel-{{ section.id }}-{{ block.id }}-{{ setup_key }}"
                      aria-pressed="{% if is_active_setup %}true{% else %}false{% endif %}"
                    >
                      <span class="sa-build-the-set__setup-indicator" aria-hidden="true"></span>
                      <span>{{ setup_label | escape }}</span>
                    </button>
                  {%- endfor -%}
                </div>
              </div>

              <div class="sa-build-the-set__setup-panels">
                {%- assign valid_setup_index = 0 -%}
                {%- for setup_key in setup_keys -%}
                  {%- liquid
                    case setup_key
                      when 'lighter_tin'
                        assign setup_products = block.settings.lighter_tin_products
                        assign setup_link = block.settings.lighter_tin_link
                        assign setup_label = section.settings.lighter_tin_label
                        assign setup_description = section.settings.lighter_tin_description
                      when 'grinder_jar_tray'
                        assign setup_products = block.settings.grinder_jar_tray_products
                        assign setup_link = block.settings.grinder_jar_tray_link
                        assign setup_label = section.settings.grinder_jar_tray_label
                        assign setup_description = section.settings.grinder_jar_tray_description
                      when 'full_smoke'
                        assign setup_products = block.settings.full_smoke_products
                        assign setup_link = block.settings.full_smoke_link
                        assign setup_label = section.settings.full_smoke_label
                        assign setup_description = section.settings.full_smoke_description
                      when 'room_decor'
                        assign setup_products = block.settings.room_decor_products
                        assign setup_link = block.settings.room_decor_link
                        assign setup_label = section.settings.room_decor_label
                        assign setup_description = section.settings.room_decor_description
                      when 'edc'
                        assign setup_products = block.settings.edc_products
                        assign setup_link = block.settings.edc_link
                        assign setup_label = section.settings.edc_label
                        assign setup_description = section.settings.edc_description
                    endcase

                    if setup_products == blank and setup_link == blank
                      continue
                    endif

                    assign valid_setup_index = valid_setup_index | plus: 1
                    assign is_active_setup = false
                    if valid_setup_index == 1
                      assign is_active_setup = true
                    endif
                    assign selection_enabled = false
                    if is_active_series and is_active_setup
                      assign selection_enabled = true
                    endif
                  -%}

                  <section
                    class="sa-build-the-set__setup-panel"
                    id="sa-build-set-setup-panel-{{ section.id }}-{{ block.id }}-{{ setup_key }}"
                    data-sa-build-set-setup-panel
                    data-setup-key="{{ setup_key }}"
                    data-setup-label="{{ setup_label | escape }}"
                    aria-hidden="{% if is_active_setup %}false{% else %}true{% endif %}"
                    {% unless is_active_setup %}hidden{% endunless %}
                  >
                    <div class="sa-build-the-set__step-heading sa-build-the-set__step-heading--products">
                      <span class="sa-build-the-set__step-number">{{ section.settings.products_step_label | escape }}</span>
                      <h2>{{ section.settings.products_heading | escape }}</h2>
                    </div>

                    <div class="sa-build-the-set__setup-intro">
                      <p class="sa-build-the-set__setup-title">{{ setup_label | escape }}</p>
                      {%- if setup_description != blank -%}
                        <p>{{ setup_description | escape }}</p>
                      {%- endif -%}
                    </div>

                    {%- if setup_products != blank -%}
                      <div class="sa-build-the-set__product-grid" role="list">
                        {%- assign selectable_variant_tokens = ',' -%}
                        {%- for product in setup_products -%}
                          {%- if product != blank -%}
                            {%- liquid
                              assign is_duplicate_variant = false
                              if product.available and product.variants.size == 1 and product.selected_or_first_available_variant.available
                                assign variant_token = product.selected_or_first_available_variant.id | append: ',' | prepend: ','
                                if selectable_variant_tokens contains variant_token
                                  assign is_duplicate_variant = true
                                else
                                  assign selectable_variant_tokens = selectable_variant_tokens | append: product.selected_or_first_available_variant.id | append: ','
                                endif
                              endif
                            -%}
                            {% render 'sa-build-set-product',
                              product: product,
                              section_id: section.id,
                              block_id: block.id,
                              product_index: forloop.index,
                              series_key: series_key,
                              setup_key: setup_key,
                              selection_enabled: selection_enabled,
                              is_duplicate_variant: is_duplicate_variant
                            %}
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- else -%}
                      <div class="sa-build-the-set__setup-empty" role="status">
                        <p>{{ section.settings.setup_empty_text | escape }}</p>
                      </div>
                    {%- endif -%}

                    {%- if setup_link != blank -%}
                      <div class="sa-build-the-set__setup-footer">
                        <a class="sa-build-the-set__cta" href="{{ setup_link }}">
                          {{ section.settings.shop_setup_label | escape }}
                        </a>
                      </div>
                    {%- endif -%}
                  </section>
                {%- endfor -%}
              </div>
            </section>
          {%- endfor -%}
        </div>

        <div
          class="sa-build-the-set__action"
          data-sa-build-set-action
          data-sa-build-set-action-host
          aria-busy="false"
          aria-label="Selected pieces"
        >
          <div class="sa-build-the-set__action-summary">
            <p class="sa-build-the-set__action-count" data-sa-build-set-count>0 pieces selected</p>
            <p class="sa-build-the-set__action-subtotal" data-sa-build-set-subtotal-row hidden>
              <span>Selected subtotal</span>
              <strong data-sa-build-set-subtotal></strong>
            </p>
            <p class="sa-build-the-set__action-helper">{{ section.settings.sold_individually_text | escape }}</p>
            <p class="sa-build-the-set__action-note" data-sa-build-set-eligibility-note hidden>
              {{ section.settings.no_selectable_text | escape }}
            </p>
          </div>
          <button
            class="sa-build-the-set__add-button"
            type="button"
            data-sa-build-set-add
            data-default-label="{{ section.settings.add_selected_label | escape }}"
            data-loading-label="{{ section.settings.adding_selected_label | escape }}"
            disabled
          >
            <span data-sa-build-set-add-label>{{ section.settings.add_selected_label | escape }}</span>
          </button>
          <p class="visually-hidden" aria-live="polite" aria-atomic="true" data-sa-build-set-status></p>
          <p class="sa-build-the-set__action-error" role="alert" data-sa-build-set-error hidden></p>
        </div>
      {%- else -%}
        <div class="sa-build-the-set__empty" role="status">
          <p>{{ section.settings.archive_empty_text | escape }}</p>
          {%- if request.design_mode -%}
            <p>Add a series block with a title and at least one product list or Shop Setup destination.</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</sa-build-the-set>

{% schema %}
{
  "name": "SA Build the Set",
  "tag": "section",
  "class": "sa-build-the-set-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SET BUILDER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build the Set"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Choose a series, select a setup, and assemble matching pieces from the archive.</p>"
    },
    {
      "type": "header",
      "content": "Page steps"
    },
    {
      "type": "text",
      "id": "series_step_label",
      "label": "Series step label",
      "default": "STEP 01"
    },
    {
      "type": "text",
      "id": "series_heading",
      "label": "Series step heading",
      "default": "CHOOSE A SERIES"
    },
    {
      "type": "text",
      "id": "setup_step_label",
      "label": "Setup step label",
      "default": "STEP 02"
    },
    {
      "type": "text",
      "id": "setup_heading",
      "label": "Setup step heading",
      "default": "PICK A SETUP"
    },
    {
      "type": "text",
      "id": "products_step_label",
      "label": "Products step label",
      "default": "STEP 03"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products step heading",
      "default": "COMPLETE YOUR SET"
    },
    {
      "type": "header",
      "content": "Series details"
    },
    {
      "type": "text",
      "id": "series_context_label",
      "label": "Series context label",
      "default": "CURRENT ARCHIVE"
    },
    {
      "type": "text",
      "id": "series_collection_label",
      "label": "Series collection link label",
      "default": "Explore the Series"
    },
    {
      "type": "header",
      "content": "Setup labels and descriptions"
    },
    {
      "type": "text",
      "id": "lighter_tin_label",
      "label": "Lighter + Tin label",
      "default": "Lighter + Tin"
    },
    {
      "type": "textarea",
      "id": "lighter_tin_description",
      "label": "Lighter + Tin description",
      "default": "Pair a collectible lighter with a matching case or companion piece."
    },
    {
      "type": "text",
      "id": "grinder_jar_tray_label",
      "label": "Grinder + Jar + Tray label",
      "default": "Grinder + Jar + Tray"
    },
    {
      "type": "textarea",
      "id": "grinder_jar_tray_description",
      "label": "Grinder + Jar + Tray description",
      "default": "Build the core three-piece smoke setup."
    },
    {
      "type": "text",
      "id": "full_smoke_label",
      "label": "Full Smoke Setup label",
      "default": "Full Smoke Setup"
    },
    {
      "type": "textarea",
      "id": "full_smoke_description",
      "label": "Full Smoke Setup description",
      "default": "Explore a broader selection of coordinated smoke accessories."
    },
    {
      "type": "text",
      "id": "room_decor_label",
      "label": "Room Decor Setup label",
      "default": "Room Decor Setup"
    },
    {
      "type": "textarea",
      "id": "room_decor_description",
      "label": "Room Decor Setup description",
      "default": "Coordinate tapestries, pillows, and display pieces."
    },
    {
      "type": "text",
      "id": "edc_label",
      "label": "EDC Setup label",
      "default": "EDC Setup"
    },
    {
      "type": "textarea",
      "id": "edc_description",
      "label": "EDC Setup description",
      "default": "Choose compact pieces for everyday carry."
    },
    {
      "type": "header",
      "content": "Actions and empty states"
    },
    {
      "type": "text",
      "id": "shop_setup_label",
      "label": "Shop Setup button label",
      "default": "Shop This Setup"
    },
    {
      "type": "text",
      "id": "setup_empty_text",
      "label": "Setup destination-only message",
      "default": "This setup is ready to explore in its dedicated archive."
    },
    {
      "type": "text",
      "id": "archive_empty_text",
      "label": "Empty archive message",
      "default": "This archive is still being curated."
    },
    {
      "type": "text",
      "id": "add_selected_label",
      "label": "Add selected button label",
      "default": "Add Selected Items"
    },
    {
      "type": "text",
      "id": "adding_selected_label",
      "label": "Add selected loading label",
      "default": "Adding selected pieces..."
    },
    {
      "type": "text",
      "id": "sold_individually_text",
      "label": "Individual pricing clarification",
      "default": "Sold individually"
    },
    {
      "type": "text",
      "id": "no_selectable_text",
      "label": "No selectable products message",
      "default": "Products with options can still be added using Choose Options."
    }
  ],
  "blocks": [
    {
      "type": "series",
      "name": "Series or design",
      "settings": [
        {
          "type": "text",
          "id": "series_title",
          "label": "Series title"
        },
        {
          "type": "collection",
          "id": "series_collection",
          "label": "Series collection"
        },
        {
          "type": "image_picker",
          "id": "series_image",
          "label": "Series image"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "accent",
          "label": "Accent color",
          "default": "#b3362d"
        },
        {
          "type": "text",
          "id": "accessibility_label",
          "label": "Accessibility label"
        },
        {
          "type": "header",
          "content": "Lighter + Tin"
        },
        {
          "type": "product_list",
          "id": "lighter_tin_products",
          "label": "Products",
          "limit": 6
        },
        {
          "type": "url",
          "id": "lighter_tin_link",
          "label": "Shop Setup destination"
        },
        {
          "type": "header",
          "content": "Grinder + Jar + Tray"
        },
        {
          "type": "product_list",
          "id": "grinder_jar_tray_products",
          "label": "Products",
          "limit": 6
        },
        {
          "type": "url",
          "id": "grinder_jar_tray_link",
          "label": "Shop Setup destination"
        },
        {
          "type": "header",
          "content": "Full Smoke Setup"
        },
        {
          "type": "product_list",
          "id": "full_smoke_products",
          "label": "Products",
          "limit": 6
        },
        {
          "type": "url",
          "id": "full_smoke_link",
          "label": "Shop Setup destination"
        },
        {
          "type": "header",
          "content": "Room Decor Setup"
        },
        {
          "type": "product_list",
          "id": "room_decor_products",
          "label": "Products",
          "limit": 6
        },
        {
          "type": "url",
          "id": "room_decor_link",
          "label": "Shop Setup destination"
        },
        {
          "type": "header",
          "content": "EDC Setup"
        },
        {
          "type": "product_list",
          "id": "edc_products",
          "label": "Products",
          "limit": 6
        },
        {
          "type": "url",
          "id": "edc_link",
          "label": "Shop Setup destination"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SA Build the Set"
    }
  ]
}
{% endschema %}
